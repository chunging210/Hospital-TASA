@{
    Layout = "_Page";
}

@section head {
    <style>
        html, body { height: 100%; overflow: hidden; }
        .bg-overlay { opacity: 0 !important; }
        .auth-page { height: 100vh; overflow: hidden; }
        .auth-page > .container-fluid,
        .auth-page > .container-fluid > .row { height: 100%; }
        .auth-page .col-12.col-lg-4 { height: 100%; overflow-y: hidden; display: flex; align-items: center; }
        .auth-page .col-12.col-lg-4 > .row { width: 100%; }
        .auth-page .col-lg-8 { height: 100%; }
        .auth-bg { height: 100% !important; }
        .auth-page .card-body.my-4 { margin-top: 0.5rem !important; margin-bottom: 0.5rem !important; }
        .auth-page .auth-logo.mb-4 { margin-bottom: 0.75rem !important; }
        .auth-page .form-floating.mb-4 { margin-bottom: 0.6rem !important; }
        .auth-page .row.g-2.mb-3 { margin-bottom: 0.5rem !important; }
        .auth-page .text-center.mb-3 { margin-bottom: 0.4rem !important; }
        .auth-page .mb-3 { margin-bottom: 0.5rem !important; }
        .auth-page .mt-4.text-center { margin-top: 0.5rem !important; }

        @@media (max-width: 576px) {
            /* input 高度縮小，padding 置中 */
            .form-floating-custom .form-control,
            .form-floating .form-control,
            .form-floating .form-select {
                height: 48px !important;
                min-height: 48px !important;
                padding-top: 12px !important;
                padding-bottom: 12px !important;
                font-size: 0.9rem !important;
            }

            /* label 預設置中顯示（空白時當作 placeholder） */
            .form-floating-custom > label,
            .form-floating > label {
                top: 60% !important;
                transform: translateY(-50%) !important;
                font-size: 0.9rem !important;
                opacity: 1 !important;
                padding-top: 0 !important;
                transition: none !important;
            }

            /* 有輸入或 focus 時隱藏 label */
            .form-floating-custom .form-control:not(:placeholder-shown) ~ label,
            .form-floating .form-control:not(:placeholder-shown) ~ label,
            .form-floating .form-select:not([value=""]) ~ label,
            .form-floating-custom .form-control:focus ~ label,
            .form-floating .form-control:focus ~ label {
                display: none !important;
            }

            /* 補回 form-floating-custom 輸入框邊框 */
            .form-floating-custom .form-control,
            .form-floating-custom .form-select {
                border: 1px solid #ced4da !important;
                border-radius: 8px !important;
            }

            /* 說明文字縮小 */
            .form-text,
            .form-text.text-muted {
                font-size: 0.72rem !important;
                line-height: 1.4 !important;
            }

            /* 註冊 modal 按鈕並排、統一高度 */
            #guestRegisterModal .modal-footer {
                flex-direction: row !important;
                gap: 8px;
                padding: 0.6rem 1rem;
            }

            #guestRegisterModal .modal-footer > * {
                flex: 1;
                height: 40px !important;
                min-height: 40px !important;
                max-height: 40px !important;
                padding: 0 0.5rem !important;
                font-size: 0.9rem !important;
                display: flex !important;
                align-items: center !important;
                justify-content: center !important;
                border-radius: 8px !important;
                box-sizing: border-box !important;
            }

            /* 覆蓋 createroom.css 造成的 modal-footer column 排列 */
            #guestRegisterModal .modal-footer {
                flex-direction: row !important;
            }

            #guestRegisterModal .modal-footer .btn {
                width: auto !important;
                margin-bottom: 0 !important;
            }

            /* 登入頁 登入/註冊 按鈕縮小 */
            .auth-page .row.g-2.mb-3 .btn-branding,
            .auth-page .row.g-2.mb-3 .btn {
                height: 40px !important;
                padding: 0 !important;
                font-size: 0.9rem !important;
                display: flex !important;
                align-items: center !important;
                justify-content: center !important;
                border-radius: 8px !important;
            }

            /* icon 縮小並置中 */
            .form-floating-custom .form-floating-icon .material-icons {
                font-size: 20px !important;
            }

            /* modal 間距縮小 */
            #guestRegisterModal .modal-body {
                padding: 0.75rem 1rem;
            }

            #guestRegisterModal .mb-3 {
                margin-bottom: 0.5rem !important;
            }

            #guestRegisterModal .mb-2 {
                margin-bottom: 0.35rem !important;
            }
        }
    </style>
}

<div id="app" v-cloak class="auth-page">
    <div class="container-fluid mw-100 p-0">
        <div class="row g-0 align-items-center">
            <div class="col-12 col-lg-4">
                <div class="row justify-content-center g-0">
                    <div class="col-xl-9 p-4">
                        <div class="card">
                            <div class="card-body my-4">
                                <div class="d-block auth-logo mb-4">
                                    <img src="/images/auth/logo-ucms.png" alt="logo" height="42" class="auth-logo-dark">
                                </div>
                                <div>
                                    <div class="text-center">
                                        <h5 class="mb-0">Welcome Back !</h5>
                                    </div>
                                    <div class="mt-4 pt-2">
                                        <div class="form-floating form-floating-custom mb-4">
                                            <input v-model="vm.Account" type="text" class="form-control"
                                                   placeholder="Account">
                                            <label>帳號/電子信箱</label>
                                            <div class="form-floating-icon">
                                                <span class="material-icons">account_circle</span>
                                            </div>
                                        </div>
                                        <div class="form-floating form-floating-custom mb-4 auth-pass-inputgroup">
                                            <input v-model="vm.Password" @@keyup.enter="auth" v-bind:type="pwType"
                                                   class="form-control" placeholder="Password">
                                            <button class="btn btn-link position-absolute h-100 end-0 top-4">
                                                <span v-if="pwType=='text'" @@click="chaangePwType"
                                                      class="material-icons vis-icons">visibility_off</span>
                                                <span v-if="pwType=='password'" @@click="chaangePwType"
                                                      class="material-icons vis-icons">visibility</span>
                                            </button>
                                            <label>密碼</label>
                                            <div class="form-floating-icon">
                                                <span class="material-icons">password</span>
                                            </div>
                                        </div>
                                        <!-- 按鈕那一排 -->
                                        <div class="row g-2 mb-3">
                                            <div class="col-6">
                                                <button @@click="auth"
                                                    class="btn-branding w-100 waves-effect waves-light text-white">
                                                    登入
                                                </button>
                                            </div>

                                            <div class="col-6">
                                                <!-- 尚未載入 -->
                                                <button v-if="!isRegistrationLoaded" disabled
                                                        class="btn btn-secondary w-100"
                                                        style="padding:0.65rem;border-radius:0.5rem;font-weight:700;">
                                                    註冊
                                                </button>

                                                <!-- 已載入 & 開放 -->
                                                <button v-else-if="isRegistrationOpen" @@click="onClickRegister"
                                                        class="btn-branding w-100 waves-effect waves-light text-white">
                                                    註冊
                                                </button>

                                                <!-- 已載入 & 關閉 -->
                                                <button v-else disabled class="btn btn-secondary w-100 "
                                                        style="padding:0.65rem;border-radius:0.5rem;font-weight:700;">
                                                    註冊
                                                </button>
                                            </div>
                                        </div>

                                        <!-- 小字提醒（獨立一行，置中） -->
                                        <div v-if="isRegistrationLoaded && !isRegistrationOpen" class="row mb-1">
                                            <div class="col-12 text-center">
                                                <small class="text-muted mt-1 d-block" style="font-size:0.8rem;">
                                                    目前尚未開放註冊
                                                </small>
                                            </div>
                                        </div>

                                        <div class="text-center mb-3">
                                            <a href="javascript:void(0)" @@click="onClickForget" class="text-muted"
                                                   style="font-size:0.9rem;">
                                                忘記密碼？
                                            </a>
                                        </div>

                                        <div class="mb-3">
                                            <a href="/availability" target="_blank"
                                                   class="btn btn-outline-secondary w-100 waves-effect"
                                                   style="border-radius: 6px; padding: 10px 20px; font-weight: 600;">
                                                <span class="material-icons"
                                                      style="vertical-align: middle; font-size: 18px; margin-right: 4px;">event_available</span>
                                                會議室預約時段查詢
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-4 text-center text-muted" style="font-size:0.75rem;">
                                    &copy; {{copyyear}} HyperNet
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- end auth full page content -->
            </div>
            <!-- end col -->
            <div class="d-none d-lg-block col-lg-8">
                <div class="auth-bg bg-white py-md-5 p-4 d-flex">
                    <div class="bg-overlay bg-white"></div>
                    <!-- end bubble effect -->
                    <div class="row justify-content-center align-items-center">
                        <img src="/images/auth/img2.png" class="img-fluid" alt="">
                    </div>
                </div>
            </div>
            <!-- end col -->
        </div>
        <!-- end row -->
    </div>
    <!-- end container fluid -->

    <div class="modal fade" id="forgetPasswordModal" tabindex="-1" aria-labelledby="forgetPasswordLabel"
         aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="forgetPasswordLabel">忘記密碼</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>
                <form @@submit.prevent="sendForgetMail">
                    <div class="modal-body">
                        <p class="text-muted mb-3">輸入您的帳號，系統將發送密碼重置連結至您的信箱</p>
                        <div class="form-floating form-floating-custom mb-3">
                            <input type="email" class="form-control" id="forgetEmail" placeholder="name@example.com"
                                   v-model="forgetForm.Account" required>
                            <label for="forgetEmail">電子信箱</label>
                            <div class="form-floating-icon">
                                <span class="material-icons">email</span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-soft-secondary" data-bs-dismiss="modal">取消</button>
                        <button type="button" class="btn btn-branding text-white" @@click="sendForgetMail">
                            送出
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="guestRegisterModal" tabindex="-1" aria-labelledby="guestRegisterLabel"
         aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="guestRegisterLabel">註冊</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
                </div>

                <form @@submit.prevent="registerGuest">

                    <div class="modal-body">
                        <!-- 使用者名稱 -->
                        <div class="form-floating form-floating-custom mb-3">
                            <input type="text" class="form-control" id="guestName" placeholder="使用者名稱"
                                   v-model="guestForm.name" required>
                            <label for="guestName">姓名</label>
                            <div class="form-floating-icon">
                                <span class="material-icons">person</span>
                            </div>
                        </div>

                        <!-- Email -->
                        <div class="form-floating form-floating-custom mb-3">
                            <input type="email" class="form-control" id="guestEmail" placeholder="name@example.com"
                                   v-model="guestForm.email" required>
                            <label for="guestEmail">Email</label>
                            <div class="form-floating-icon">
                                <span class="material-icons">email</span>
                            </div>
                        </div>

                        <!-- 密碼 -->
                        <div class="form-floating form-floating-custom mb-2">
                            <input type="password" class="form-control" id="guestPassword" placeholder="密碼"
                                   v-model="guestForm.password" required>
                            <label for="guestPassword">密碼</label>
                            <div class="form-floating-icon">
                                <span class="material-icons">lock</span>
                            </div>
                        </div>
                        <div class="form-text text-muted mb-3" style="font-size: 0.8rem;">
                            <span class="material-icons" style="font-size: 14px; vertical-align: middle;">info</span>
                            密碼須至少 8 個字元，並包含大寫字母、小寫字母、數字、特殊符號（@@$!%*?&-_#^）中的任意三種
                        </div>

                        <!-- 確認密碼 -->
                        <div class="form-floating form-floating-custom mb-3">
                            <input type="password" class="form-control" id="guestPassword2" placeholder="再次輸入密碼"
                                   v-model="guestForm.confirmPassword" required>
                            <label for="guestPassword2">確認密碼</label>
                            <div class="form-floating-icon">
                                <span class="material-icons">lock</span>
                            </div>
                        </div>

                        <!-- 選擇分院 -->
                        <div class="form-floating mb-2">
                            <select class="form-select" v-model="guestForm.departmentId">
                                <option :value="null">其他（院外人士）</option>
                                <option v-for="d in departments" :key="d.Id" :value="d.Id">
                                    {{ d.Name }}
                                </option>
                            </select>
                            <label>所屬分院（非必填）</label>
                        </div>

                        <div class="form-text text-muted mb-3">
                            <span class="material-icons" style="font-size: 16px; vertical-align: middle;">info</span>
                            未選擇分院將註冊為一般會員；若您為院內職員，請選擇所屬分院。
                        </div>

                        <!-- 部門 -->
                        <div class="form-floating form-floating-custom mb-3">
                            <input type="text" class="form-control" id="guestUnitName" placeholder="部門"
                                   v-model="guestForm.unitName" required>
                            <label for="guestUnitName">部門/其他團體</label>
                            <div class="form-floating-icon">
                                <span class="material-icons">business</span>
                            </div>
                        </div>

                        <!-- 驗證碼 -->
                        <div class="mb-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <label class="form-label mb-0">驗證碼</label>
                                <div class="d-flex align-items-center gap-2">
                                <img :src="registerCaptchaSrc"
                                     alt="驗證碼"
                                     style="height: 40px; border: 1px solid #dee2e6; border-radius: 4px; cursor: pointer;"
                                     @@click="refreshRegisterCaptcha"
                                     title="點擊重新產生">
                                <button type="button" class="btn btn-outline-secondary btn-sm" @@click="refreshRegisterCaptcha">
                                    <span class="material-icons" style="font-size: 18px; vertical-align: middle;">refresh</span>
                                </button>
                                </div>
                            </div>
                            <input type="text"
                                   class="form-control mt-2"
                                   placeholder="請輸入上方驗證碼"
                                   v-model="guestForm.captcha"
                                   @@input="upperCaptcha"
                                   maxlength="4"
                                   required>
                            <small class="text-muted">點擊圖片可重新產生驗證碼</small>
                        </div>

                        @* <!-- 服務條款同意 -->
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="agreeTerms" 
                            v-model="guestForm.agreeTerms" required>
                        <label class="form-check-label" for="agreeTerms">
                            我已閱讀並同意 <a href="#" target="_blank">服務條款</a> 與 <a href="#" target="_blank">隱私權政策</a>
                        </label>
                    </div> *@
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-soft-secondary" data-bs-dismiss="modal">取消</button>
                        <button type="button" class="btn btn-branding text-white" @@click="registerGuest">
                            註冊
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

</div>