<link rel="stylesheet" href="/css/conference.css">
<div class="page-content" v-cloak>
    <div class="container-fluid vstack gap-3">
        <div class="card">
            <div class="card-header mx-4 mt-3">
                <!-- 主列：標題 + 日期 + 關鍵字 + 進階篩選按鈕（同一排） -->
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <div class="text-branding d-flex align-items-center flex-shrink-0">
                        <span class="material-icons">calendar_month</span>會議總覽
                    </div>
                    <!-- 日期範圍：未選會議室 或 列表視圖 -->
                    <div v-show="!conference.query.RoomId || conference.viewMode.value === 'list'"
                         style="min-width:260px; flex:1 1 260px;">
                        <div class="input-group">
                            <input v-model="conference.query.Start" type="date" class="form-control">
                            <span class="input-group-text">~</span>
                            <input v-model="conference.query.End" type="date" class="form-control">
                        </div>
                    </div>
                    <!-- 單一日期：選了會議室 + 非列表視圖 -->
                    <div v-show="conference.query.RoomId && conference.viewMode.value !== 'list'"
                         style="min-width:160px;">
                        <input type="date" class="form-control"
                               :value="conference.formatSelectedDate()"
                               @@change="conference.onDatePickerChange($event)">
                    </div>
                    <!-- 關鍵字 -->
                    <div style="min-width:180px; flex:1 1 180px;">
                        <input type="text" class="form-control"
                               v-model="conference.query.keyword"
                               placeholder="搜尋關鍵字...">
                    </div>
                    <!-- 進階篩選按鈕 -->
                    <div class="ms-auto flex-shrink-0">
                        <button class="btn d-flex align-items-center gap-2"
                                :class="conference.showAdvancedFilter.value ? 'btn-primary' : 'btn-outline-secondary'"
                                @@click="conference.showAdvancedFilter.value = !conference.showAdvancedFilter.value">
                            <span class="material-icons" style="font-size:16px;">tune</span>
                            進階篩選
                        </button>
                    </div>
                </div>

                <!-- 進階篩選區塊 -->
                <div v-show="conference.showAdvancedFilter.value"
                     class="rounded mt-2 p-3" style="background:#f4f6f8;">
                    <div class="row g-2">
                        <!-- 大樓篩選 -->
                        <div class="col-12 col-md-4">
                            <select v-model="conference.query.Building" @@change="conference.onBuildingChange"
                                    class="form-select">
                                <option value="">全部大樓</option>
                                <option v-for="item in building.list" :value="item.Building">{{item.Building}}</option>
                            </select>
                        </div>
                        <!-- 會議室篩選 -->
                        <div class="col-12 col-md-4">
                            <select v-model="conference.query.RoomId" @@change="conference.onRoomChange"
                                    class="form-select">
                                <option value="">全部會議室</option>
                                <option v-for="{Id,Name} in conference.filteredRoomList.value" :value="Id">{{Name}}</option>
                            </select>
                        </div>
                        <!-- 部門代碼篩選 -->
                        <div class="col-12 col-md-4 position-relative unitname-search-wrap">
                            <div class="input-group">
                                <input type="text" class="form-control"
                                       v-model="deptSearch.keyword.value"
                                       @@input="deptSearch.filter()"
                                       @@focus="deptSearch.showDropdown.value = true"
                                       placeholder="篩選部門代碼..." autocomplete="off">
                                <button v-if="deptSearch.keyword.value" class="btn btn-outline-secondary"
                                        type="button" @@click="deptSearch.clear()">
                                    <span class="material-icons" style="font-size:16px;">close</span>
                                </button>
                            </div>
                            <div v-if="deptSearch.showDropdown.value && deptSearch.filtered.length > 0"
                                 class="unitname-dropdown">
                                <div v-for="item in deptSearch.filtered" :key="item.code"
                                     class="unitname-item" @@click="deptSearch.select(item)">
                                    <strong>{{ item.code }}</strong> - {{ item.name }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <!-- 選了會議室才顯示視圖切換 -->
                <div v-if="conference.query.RoomId"
                     class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <!-- 視圖切換 -->
                    <div class="btn-group btn-group-sm">
                        <button type="button" class="btn"
                                :class="conference.viewMode.value === 'list' ? 'btn-primary' : 'btn-outline-secondary'"
                            @@click="conference.setViewMode('list')">
                            列表
                        </button>
                        <button type="button" class="btn"
                                :class="conference.viewMode.value === 'day' ? 'btn-primary' : 'btn-outline-secondary'"
                            @@click="conference.setViewMode('day')">
                            日
                        </button>
                        <button type="button" class="btn"
                                :class="conference.viewMode.value === 'week' ? 'btn-primary' : 'btn-outline-secondary'"
                            @@click="conference.setViewMode('week')">
                            週
                        </button>
                        <button type="button" class="btn"
                                :class="conference.viewMode.value === 'month' ? 'btn-primary' : 'btn-outline-secondary'"
                            @@click="conference.setViewMode('month')">
                            月
                        </button>
                    </div>

                    <!-- 日期導航 -->
                    <div class="d-flex align-items-center gap-2" v-if="conference.viewMode.value !== 'list'">
                        <button class="btn btn-outline-secondary btn-sm" @@click="conference.navigate(-1)">
                            <span class="material-icons" style="font-size: 18px;">chevron_left</span>
                        </button>
                        <span class="fw-bold px-2" style="min-width: 150px; text-align: center;">{{
                            conference.dateTitle.value }}</span>
                            <button class="btn btn-outline-secondary btn-sm" @@click="conference.navigate(1)">
                                <span class="material-icons" style="font-size: 18px;">chevron_right</span>
                            </button>
                            <button class="btn btn-outline-primary btn-sm" @@click="conference.goToToday()">今天</button>
                        </div>
                    </div>

                    <!-- Loading -->
                    <div v-if="conference.calendarLoading.value" class="text-center py-5">
                        <div class="spinner-border text-primary"></div>
                    </div>

                    <!-- ==================== 列表視圖 ==================== -->
                    <div v-show="conference.viewMode.value === 'list' && !conference.calendarLoading.value">
                        <table class="table table-hover table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>會議名稱</th>
                                    <th>承辦單位</th>
                                    <th>日期</th>
                                    <th v-if="!conference.query.RoomId">地點</th>
                                    <th>發起人</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="item in conference.list" :key="item.Id">
                                    <td class="text-truncate" style="max-width: 250px;">{{item.Name}}</td>
                                    <td>{{item.OrganizerUnit || '-'}}</td>
                                    <td>
                                        <template v-if="item.SlotDate">{{ item.SlotDate }}<template
                                            v-if="item.SlotDateEnd && item.SlotDate !== item.SlotDateEnd"> ~ {{
                                            item.SlotDateEnd }}</template></template>
                                            <template v-else>{{ item.StartTime ? item.StartTime.format('yyyy-mm-dd') : '-'
                                                }}</template>
                                            </td>
                                            <td v-if="!conference.query.RoomId">{{item.RoomLocation || '-'}}</td>
                                            <td>{{item.CreateByName}}</td>
                                        </tr>
                                    </tbody>
                                    <tfoot v-if="conference.list.length==0">
                                        <tr>
                                            <td :colspan="conference.query.RoomId ? 4 : 5" class="text-center text-muted py-4">查無資料
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                                <page ref="conferencepage" :per-page="20" :per-page-option="[20,40,60]"
                                @@reload="conference.getList"></page>
                            </div>

                            <!-- ==================== 日視圖（單一會議室） ==================== -->
                            <div
                                v-show="conference.viewMode.value === 'day' && !conference.calendarLoading.value && conference.query.RoomId">
                                <div class="table-responsive">
                                    <table class="table table-bordered mb-0">
                                        <thead class="table-dark text-center">
                                            <tr>
                                                <th style="width: 110px; white-space: nowrap;">時段</th>
                                                <th>會議名稱</th>
                                                <th>部門</th>
                                                <th>承辦單位</th>
                                                <th style="width: 80px;">人數</th>
                                                <th style="width: 120px;">聯絡電話</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr v-for="slot in conference.roomSlots" :key="slot.TimeLabel"
                                                :class="slot.Occupied ? 'slot-occupied' : 'slot-empty'">
                                                <td class="fw-semibold text-nowrap text-center">{{ slot.TimeLabel }}</td>
                                                <td>{{ slot.ConferenceName || '' }}</td>
                                                <td>{{ slot.CreatorUnitName || '' }}</td>
                                                <td>{{ slot.OrganizerUnit || '' }}</td>
                                                <td class="text-center">{{ slot.ExpectedAttendees || '' }}</td>
                                                <td>{{ slot.ContactPhone || '' }}</td>
                                            </tr>
                                        </tbody>
                                        <tfoot v-if="!conference.roomSlots?.length">
                                            <tr>
                                                <td colspan="6" class="text-center text-muted py-4">此會議室今日無開放時段</td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>

                            <!-- ==================== 週視圖（單一會議室） ==================== -->
                            <div
                                v-show="conference.viewMode.value === 'week' && !conference.calendarLoading.value && conference.query.RoomId">
                                <div class="table-responsive">
                                    <table class="table table-bordered mb-0">
                                        <thead class="table-dark text-center">
                                            <tr>
                                                <th style="min-width: 120px; width: 120px; white-space: nowrap;">時段</th>
                                                <th v-for="day in conference.weekDays.value" :key="day.date" class="text-center">
                                                    {{ day.label }}<br><small>{{ day.dateShort }}</small>
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr v-for="(slot, idx) in conference.weekSlots" :key="idx">
                                                <td class="fw-semibold text-nowrap text-center slot-empty">{{ slot.TimeLabel }}</td>
                                                <td v-for="(day, dayIdx) in conference.weekDays.value" :key="dayIdx"
                                                    class="text-center p-1 small"
                                                    :class="slot.DayList[dayIdx].Occupied ? 'slot-occupied' : 'slot-empty'">
                                                    {{ slot.DayList[dayIdx].ConferenceName }}
                                                </td>
                                            </tr>
                                        </tbody>
                                        <tfoot v-if="conference.weekSlots.length === 0">
                                            <tr>
                                                <td colspan="8" class="text-center text-muted py-4">此會議室無開放時段</td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>

                            <!-- ==================== 月視圖（單一會議室） ==================== -->
                            <div
                                v-show="conference.viewMode.value === 'month' && !conference.calendarLoading.value && conference.query.RoomId">
                                <table class="table table-bordered mb-0" style="table-layout: fixed;">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="text-center py-2">一</th>
                                            <th class="text-center py-2">二</th>
                                            <th class="text-center py-2">三</th>
                                            <th class="text-center py-2">四</th>
                                            <th class="text-center py-2">五</th>
                                            <th class="text-center py-2 text-danger">六</th>
                                            <th class="text-center py-2 text-danger">日</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr v-for="(week, idx) in conference.monthViewData.Weeks" :key="idx">
                                            <td v-for="day in week" :key="day.Date"
                                                :class="{ 'table-warning': day.IsToday, 'bg-light': !day.IsCurrentMonth }"
                                                class="p-1" style="height: 90px; vertical-align: top; cursor: pointer;"
                                                @@click="conference.goToDate(day.Date)">
                                                <div class="d-flex justify-content-between mb-1">
                                                    <span
                                                        :class="{ 'fw-bold': day.IsToday, 'text-danger': day.IsWeekend && day.IsCurrentMonth, 'text-muted': !day.IsCurrentMonth }">{{
                                                        day.Day }}</span>
                                                    </div>
                                                    <div v-if="day.IsCurrentMonth && day.Conferences?.length"
                                                         class="d-flex flex-column gap-1" style="font-size: 10px;">
                                                        <div v-for="conf in day.Conferences.slice(0, 3)" :key="conf.Id"
                                                             class="text-truncate bg-primary text-white rounded px-1" :title="conf.Name">
                                                            {{ conf.Name }}
                                                        </div>
                                                        <div v-if="day.Conferences.length > 3" class="text-muted text-center">
                                                            +{{ day.Conferences.length - 3 }} 場
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <div class="mt-2 small text-muted">
                                        <span class="material-icons" style="font-size: 14px; vertical-align: middle;">touch_app</span>
                                        點擊日期可切換至日視圖
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

                @{
                    ViewBag.IsTemplate = false;
                }