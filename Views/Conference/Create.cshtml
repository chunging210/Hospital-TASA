<link rel="stylesheet" href="/css/createroom.css">

<div id="app" v-cloak class="main-content">
    <div class="page-content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <!-- Header -->
                        <div class="card-header mx-4 mt-3">
                            <div class="row align-items-center">
                                <div class="col-xl-9 col-sm-12 text-branding align-middle">
                                    <span class="material-icons title-icons">edit_calendar</span> {{ isEditMode ?
                                    '編輯會議預約' :
                                    '新增會議預約' }}
                                </div>
                                <div class="col-xl-3 col-sm-12 df-box01">
                                    <div class="d-flex align-items-center me-3">
                                        <div class="flex-grow-1">
                                            <p class="text-muted mb-1">發起會議者</p>
                                            <h4 class="mb-0">{{ initiatorName }}</h4>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Body -->
                        <div class="card-body">
                            <ol class="activity-checkout mb-0 px-4 mt-3">

                                <!-- 1. 會議基本資訊 -->
                                <li class="checkout-item">
                                    <div class="avatar checkout-icon p-1">
                                        <div class="avatar-title rounded-circle bg-primary">
                                            <span class="material-icons room-icons">edit_note</span>
                                        </div>
                                    </div>
                                    <div class="feed-item-list">
                                        <form>
                                            <div class="mb-3 row align-items-top">
                                                <div class="col-sm-12 col-xl-auto pe-0">
                                                    <label class="col-form-label pe-3">會議類型</label>
                                                </div>
                                                <div class="col-sm-12 col-xl-10">
                                                    <div class="row">
                                                        <div class="col-sm-12 col-xl-3 mb-2">
                                                            <select class="form-select" v-model="form.meetingType">
                                                                <option value="physical">實體會議</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- 會議名稱 -->
                                            <div class="form-floating mb-3">
                                                <input type="text" class="form-control" id="meetingName"
                                                       placeholder="請填寫會議名稱" v-model="form.name" required>
                                                <label for="meetingName" class="ms-2">會議名稱 <span class="text-danger">*</span></label>
                                            </div>

                                            <!-- 會議內容 -->
                                            <div class="form-floating mb-3">
                                                <textarea class="form-control" id="meetingContent" placeholder="請填寫會議內容"
                                                          style="height: 180px" v-model="form.content"></textarea>
                                                <label for="meetingContent" class="ms-2">會議內容</label>
                                            </div>

                                            <!-- 承辦單位 & 會議主席 & 預計人數 -->
                                            <div class="row">
                                                <div class="col-xl-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="text" class="form-control" id="organizerUnit"
                                                               placeholder="請填寫承辦單位" v-model="form.organizerUnit">
                                                        <label for="organizerUnit" class="ms-2">承辦單位 <span class="text-danger">*</span></label>
                                                    </div>
                                                </div>
                                                <div class="col-xl-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="text" class="form-control" id="chairman"
                                                               placeholder="請填寫會議主席" v-model="form.chairman">
                                                        <label for="chairman" class="ms-2">會議主席 <span class="text-danger">*</span></label>
                                                    </div>
                                                </div>
                                                <div class="col-xl-4">
                                                    <div class="form-floating mb-3">
                                                        <input type="number" class="form-control" id="expectedAttendees"
                                                               placeholder="請填寫人數" v-model.number="form.expectedAttendees" min="1">
                                                        <label for="expectedAttendees" class="ms-2">預計到達人數</label>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- 聯絡電話 & 電子郵件 (必填) -->
                                            <div class="row">
                                                <div class="col-xl-6">
                                                    <div class="form-floating mb-3">
                                                        <input type="tel" class="form-control" id="contactPhone"
                                                               placeholder="請填寫聯絡電話" v-model="form.contactPhone"
                                                               @@input="form.contactPhone = $event.target.value.replace(/[^0-9]/g, '')"
                                                               pattern="[0-9]*" inputmode="numeric" required>
                                                        <label for="contactPhone" class="ms-2">聯絡電話 <span class="text-danger">*</span></label>
                                                    </div>
                                                </div>
                                                <div class="col-xl-6">
                                                    <div class="form-floating mb-3">
                                                        <input type="email" class="form-control" id="contactEmail"
                                                               placeholder="請填寫電子郵件" v-model="form.contactEmail" required>
                                                        <label for="contactEmail" class="ms-2">電子郵件 <span class="text-danger">*</span></label>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- 循環預約開關（僅院內人員、新增模式才顯示） -->
                                            <div class="row mb-3" v-if="isInternalStaff && !isEditMode">
                                                <div class="col-xl-12">
                                                    <div class="form-check form-switch">
                                                        <input class="form-check-input" type="checkbox" id="isRecurring"
                                                               v-model="form.isRecurring"
                                                               @@change="onRecurringToggle">
                                                        <label class="form-check-label fw-semibold" for="isRecurring">
                                                            <span class="material-icons align-middle" style="font-size:18px">repeat</span>
                                                            循環預約
                                                            <small class="text-muted">（僅限成本分攤付款）</small>
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- 一般預約：開始日期 + 結束日期 -->
                                            <div class="row" v-if="!form.isRecurring">
                                                <div class="col-xl-12">
                                                    <div class="row g-3 align-items-end">
                                                        <div class="col-sm-12 col-xl-3">
                                                            <label class="col-form-label">開始日期 <span class="text-danger">*</span></label>
                                                            <input class="form-control" type="date" v-model="form.startDate"
                                                                   :min="minBookingDate"
                                                                   :max="maxBookingDate"
                                                                   @@change="!form.endDate && (form.endDate = form.startDate)">
                                                        </div>
                                                        <div class="col-sm-12 col-xl-3">
                                                            <label class="col-form-label">結束日期 <span class="text-danger">*</span></label>
                                                            <input class="form-control" type="date" v-model="form.endDate"
                                                                   :min="form.startDate || minBookingDate"
                                                                   :max="maxEndDate">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- 循環預約：所有設定在同一個區塊 -->
                                            <div class="row" v-if="form.isRecurring">
                                                <div class="col-xl-12">
                                                    <div class="border rounded p-3 bg-light">
                                                        <div class="row g-3 align-items-end">
                                                            <!-- 開始日期 -->
                                                            <div class="col-sm-12 col-xl-3">
                                                                <label class="col-form-label">開始日期 <span class="text-danger">*</span></label>
                                                                <input class="form-control" type="date" v-model="form.startDate"
                                                                       :min="minBookingDate"
                                                                       :max="maxBookingDate">
                                                            </div>

                                                            <!-- 循環類型 -->
                                                            <div class="col-sm-12 col-xl-2">
                                                                <label class="col-form-label">循環類型 <span class="text-danger">*</span></label>
                                                                <select class="form-select" v-model="form.recurrenceType">
                                                                    <option value="daily">每日</option>
                                                                    <option value="weekly">每週</option>
                                                                    <option value="monthly">每月</option>
                                                                </select>
                                                            </div>

                                                            <!-- 每月：選幾號 -->
                                                            <div class="col-sm-12 col-xl-2" v-if="form.recurrenceType === 'monthly'">
                                                                <label class="col-form-label">每月幾號 <span class="text-danger">*</span></label>
                                                                <input class="form-control" type="number" min="1" max="31"
                                                                       v-model.number="form.recurrenceDayOfMonth"
                                                                       placeholder="1-31">
                                                            </div>

                                                            <!-- 循環結束日期 -->
                                                            <div class="col-sm-12 col-xl-3">
                                                                <label class="col-form-label">循環至 <span class="text-danger">*</span></label>
                                                                <input class="form-control" type="date" v-model="form.recurrenceEndDate"
                                                                       :min="form.startDate || minBookingDate"
                                                                       :max="maxBookingDate">
                                                            </div>
                                                        </div>

                                                        <!-- 每週：選星期幾 -->
                                                        <div class="row mt-3" v-if="form.recurrenceType === 'weekly'">
                                                            <div class="col-12">
                                                                <label class="col-form-label">選擇星期 <span class="text-danger">*</span></label>
                                                                <div class="d-flex flex-wrap gap-2 mt-1">
                                                                    <div v-for="(label, idx) in ['日','一','二','三','四','五','六']" :key="idx"
                                                                         class="form-check form-check-inline">
                                                                        <input class="form-check-input" type="checkbox"
                                                                               :id="'dow-' + idx"
                                                                               :value="idx"
                                                                               v-model="form.recurrenceDaysOfWeek">
                                                                        <label class="form-check-label" :for="'dow-' + idx">週{{ label }}</label>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <!-- 預覽日期清單 -->
                                                        <div class="mt-3" v-if="previewRecurringDates.length > 0">
                                                            <label class="col-form-label fw-semibold">
                                                                <span class="material-icons align-middle text-success" style="font-size:18px">event_available</span>
                                                                預計建立 {{ previewRecurringDates.length }} 筆預約：
                                                            </label>
                                                            <div class="d-flex flex-wrap gap-1 mt-1" style="max-height:100px;overflow-y:auto">
                                                                <span v-for="d in previewRecurringDates" :key="d"
                                                                      class="badge bg-secondary">{{ d }}</span>
                                                            </div>
                                                        </div>
                                                        <div class="mt-2 text-muted small" v-else-if="form.startDate && form.recurrenceEndDate">
                                                            <span class="material-icons align-middle text-warning" style="font-size:16px">warning</span>
                                                            目前設定無可建立的日期，請確認循環條件。
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        </form>
                                    </div>
                                    <hr>
                                </li>

                                <!-- 2. 與會人員 -->
                                <li class="checkout-item">
                                    <div class="avatar checkout-icon p-1">
                                        <div class="avatar-title rounded-circle bg-primary">
                                            <span class="material-icons room-icons">groups</span>
                                        </div>
                                    </div>
                                    <div class="feed-item-list">
                                        <form>
                                            <div class="mb-3 row align-items-top">
                                                <div class="col-sm-12 col-xl-auto pe-0">
                                                    <label class="col-form-label pe-3">與會人員</label>
                                                </div>
                                                <div class="col-sm-12 col-xl-10">
                                                    <div class="alert alert-light border">
                                                        <div class="d-flex align-items-center justify-content-between">
                                                            <div>
                                                                <h6 class="mb-1">發起人</h6>
                                                                <p class="mb-0 text-muted">{{ initiatorName }}</p>
                                                            </div>
                                                            <span class="badge bg-primary">主持人</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                    <hr>
                                </li>

                                <!-- 3. 與會地點 -->
                                <li class="checkout-item">
                                    <div class="avatar checkout-icon p-1">
                                        <div class="avatar-title rounded-circle bg-primary">
                                            <span class="material-icons room-icons">edit_location_alt</span>
                                        </div>
                                    </div>

                                    <div class="feed-item-list">
                                        <form class="pb-2">
                                            <div class="mb-3 row align-items-stretch">
                                                <div class="col-sm-12 col-xl-auto pe-0">
                                                    <label class="col-form-label pe-3">與會地點</label>
                                                </div>

                                                <div class="col-sm-12 col-xl-10">

                                                    <div class="row g-2">

                                                        <!-- 分院（只有全院管理者才顯示） -->
                                                        <div class="col-sm-12 col-xl-3" v-if="isGlobalAdmin">
                                                            <select class="form-select" v-model="form.departmentId">
                                                                <option :value="null">請選擇分院</option>
                                                                <option v-for="d in departments" :key="d.Id"
                                                                        :value="d.Id">
                                                                    {{ d.Name }}
                                                                </option>
                                                            </select>
                                                        </div>

                                                        <!-- 大樓 -->
                                                        <div class="col-sm-12 col-xl-3">
                                                            <select class="form-select" v-model="form.building"
                                                                    :disabled="!form.departmentId">
                                                                <option value="">請選擇大樓</option>
                                                                <option v-for="b in buildings" :key="b.Building"
                                                                        :value="b.Building">
                                                                    {{ b.Building }}
                                                                </option>
                                                            </select>
                                                        </div>

                                                        <!-- 樓層 -->
                                                        <div class="col-sm-12 col-xl-3">
                                                            <select class="form-select" v-model="form.floor"
                                                                    :disabled="!form.building">
                                                                <option value="">請選擇樓層</option>
                                                                <option v-for="f in availableFloors" :key="f"
                                                                        :value="f">
                                                                    {{ f }}
                                                                </option>
                                                            </select>
                                                        </div>

                                                        <!-- 會議室 -->
                                                        <div class="col-sm-12 col-xl-3">
                                                            <select class="form-select" v-model="form.roomId"
                                                                    :disabled="!form.floor">
                                                                <option :value="null">請選擇會議室</option>
                                                                <option v-for="room in filteredRooms" :key="room.Id"
                                                                        :value="room.Id">
                                                                    {{ room.Name }}
                                                                </option>
                                                            </select>
                                                        </div>

                                                    </div>

                                                    <!-- 時段選擇（統一使用 dateRange） -->
                                                    <div v-if="form.roomId && dateRange.length > 0" class="mt-4">
                                                        <label class="form-label">選擇時段{{ dateRange.length > 1 ? '（分日選擇）' : '' }}</label>
                                                        <span v-if="selectedRoom && selectedRoom.BookingSettings === 3"
                                                              class="badge bg-success ms-2">
                                                            <i class="bx bx-gift"></i> 免費使用
                                                        </span>

                                                        <!-- 日期 Tab 導航 -->
                                                        <ul class="nav nav-tabs mb-3" role="tablist">
                                                            <li class="nav-item" v-for="(dateStr, index) in dateRange" :key="dateStr" role="presentation">
                                                                <button class="nav-link" :class="{ active: activeTab === dateStr, 'text-danger': middleDayErrors[dateStr] }"
                                                                        @@click="activeTab = dateStr" type="button" role="tab">
                                                                    {{ formatTabDate(dateStr) }}
                                                                    @* <span v-if="isFirstDay(dateStr) && !isLastDay(dateStr)" class="badge bg-success ms-1" title="首日：從最後時段開始選">
                                                                        首日
                                                                    </span>
                                                                    <span v-if="isLastDay(dateStr) && !isFirstDay(dateStr)" class="badge bg-warning text-dark ms-1" title="末日：從第一時段開始選">
                                                                        末日
                                                                    </span>
                                                                    <span v-if="isMiddleDay(dateStr)" class="badge bg-info ms-1" title="中間天自動全選">
                                                                        全天
                                                                    </span> *@
                                                                    @* <span v-if="middleDayErrors[dateStr]" class="badge bg-danger ms-1">
                                                                        <i class="bx bx-error-circle"></i>
                                                                    </span>
                                                                    <span v-else-if="getSelectedCountForDate(dateStr) > 0" class="badge bg-primary ms-1">
                                                                        {{ getSelectedCountForDate(dateStr) }}
                                                                    </span> *@
                                                                </button>
                                                            </li>
                                                        </ul>

                                                        <!-- Tab 內容 -->
                                                        <div class="tab-content">
                                                            <div v-for="dateStr in dateRange" :key="'content-' + dateStr"
                                                                 class="tab-pane" :class="{ 'show active': activeTab === dateStr }">

                                                                @* <!-- 首日提示 -->
                                                                <div v-if="isFirstDay(dateStr) && !isLastDay(dateStr)" class="alert alert-info mb-3">
                                                                    <i class="bx bx-info-circle"></i>
                                                                    <strong>首日：</strong>請從<span class="text-danger fw-bold">最後時段</span>開始選擇，往前擴展。選擇必須連續到當天結束，才能與隔天銜接。
                                                                </div>

                                                                <!-- 末日提示 -->
                                                                <div v-if="isLastDay(dateStr) && !isFirstDay(dateStr)" class="alert alert-info mb-3">
                                                                    <i class="bx bx-info-circle"></i>
                                                                    <strong>末日：</strong>請從<span class="text-danger fw-bold">第一時段</span>開始選擇，往後擴展。選擇必須從當天開始，才能與前一天銜接。
                                                                </div>

                                                                <!-- 中間天提示 -->
                                                                <div v-if="isMiddleDay(dateStr)" class="alert alert-warning mb-3">
                                                                    <i class="bx bx-info-circle"></i>
                                                                    <strong>中間天：</strong>系統自動選取所有時段，您可以調整每個時段的使用類型（一般/場佈）
                                                                </div> *@

                                                                <!-- 載入中 -->
                                                                <div v-if="loadingSlots[dateStr]" class="text-center py-4">
                                                                    <div class="spinner-border text-primary" role="status">
                                                                        <span class="visually-hidden">載入中...</span>
                                                                    </div>
                                                                </div>

                                                                <!-- 中間天被佔用錯誤 -->
                                                                <div v-else-if="middleDayErrors[dateStr]" class="alert alert-danger">
                                                                    <i class="bx bx-error-circle"></i>
                                                                    {{ middleDayErrors[dateStr] }}
                                                                </div>

                                                                <!-- 時段選擇 -->
                                                                <div v-else>

                                                                    <!-- ===== 時段制：分組顯示 ===== -->
                                                                    <div v-if="isPeriodMode">
                                                                        <div v-for="group in getPeriodGroupsForDate(dateStr)" :key="group.periodId" class="mb-3">

                                                                            <!-- 主區間 header -->
                                                                            <div class="d-flex align-items-center justify-content-between px-3 py-2 rounded-top border"
                                                                                 :class="isPeriodGroupSelected(dateStr, group.periodId) ? 'border-primary bg-primary bg-opacity-10' : 'bg-light border-bottom-0'">
                                                                                <div class="d-flex align-items-center gap-2">
                                                                                    <strong>{{ group.name }}</strong>
                                                                                    <span class="text-muted small">{{ group.startTime.slice(0,5) }} - {{ group.endTime.slice(0,5) }}</span>
                                                                                    <span v-if="isHolidayForDate(dateStr) && group.holidayPrice"
                                                                                          class="badge bg-warning text-dark" style="font-size:0.7rem">假日</span>
                                                                                </div>
                                                                                <div class="d-flex align-items-center gap-3">
                                                                                    <!-- 價格說明 -->
                                                                                    <span class="text-muted small">
                                                                                        <span v-if="selectedRoom && selectedRoom.BookingSettings === 3">免費</span>
                                                                                        <span v-else>
                                                                                            ${{ isHolidayForDate(dateStr) && group.holidayPrice ? group.holidayPrice : group.price }}
                                                                                            <span v-if="group.setupPrice" class="ms-1 text-warning">場佈 ${{ group.setupPrice }}</span>
                                                                                        </span>
                                                                                    </span>
                                                                                    <!-- 一般/場佈切換（有選且有場佈價才顯示） -->
                                                                                    <div v-if="isPeriodGroupSelected(dateStr, group.periodId) && group.setupPrice"
                                                                                         class="btn-group btn-group-sm" @@click.stop>
                                                                                        <button type="button" class="btn"
                                                                                                :class="!periodGroupSetup[dateStr]?.[group.periodId] ? 'btn-primary' : 'btn-outline-primary'"
                                                                                                @@click="setPeriodGroupSetup(dateStr, group.periodId, false)">一般</button>
                                                                                        <button type="button" class="btn"
                                                                                                :class="periodGroupSetup[dateStr]?.[group.periodId] ? 'btn-warning' : 'btn-outline-warning'"
                                                                                                @@click="setPeriodGroupSetup(dateStr, group.periodId, true)">場佈</button>
                                                                                    </div>
                                                                                </div>
                                                                            </div>

                                                                            <!-- 子區間卡片列 -->
                                                                            <div class="d-flex flex-wrap gap-2 p-2 border rounded-bottom"
                                                                                 :class="isPeriodGroupSelected(dateStr, group.periodId) ? 'border-primary' : ''">
                                                                                <div v-for="slot in getSlotsForGroup(dateStr, group.periodId)"
                                                                                     :key="dateStr + '-' + slot.Key"
                                                                                     class="time-slot-card flex-shrink-0"
                                                                                     style="min-width:100px"
                                                                                     :class="{
                                                                                        selected: isSlotSelectedForDate(dateStr, slot) && !isSlotSetupForDate(dateStr, slot),
                                                                                        'selected-setup': isSlotSelectedForDate(dateStr, slot) && isSlotSetupForDate(dateStr, slot),
                                                                                        occupied: slot.Occupied,
                                                                                        disabled: !isSlotAvailableForDate(dateStr, slot)
                                                                                     }" @@click="toggleTimeSlotForDate(dateStr, slot)">
                                                                                    <div class="slot-time">
                                                                                        <div class="text-muted small">{{ slot.StartTime.slice(0,5) }} - {{ slot.EndTime.slice(0,5) }}</div>
                                                                                    </div>
                                                                                    <div v-if="slot.Occupied" class="slot-price"><span>已預約</span></div>
                                                                                </div>
                                                                            </div>

                                                                        </div>
                                                                    </div>

                                                                    <!-- ===== 小時制：原本卡片格式 ===== -->
                                                                    <div v-else class="time-slot-grid">
                                                                        <div v-for="slot in slotsByDate[dateStr]" :key="dateStr + '-' + slot.Key"
                                                                             class="time-slot-card" :class="{
                                                                            selected: isSlotSelectedForDate(dateStr, slot) && !isSlotSetupForDate(dateStr, slot),
                                                                            'selected-setup': isSlotSelectedForDate(dateStr, slot) && isSlotSetupForDate(dateStr, slot),
                                                                            occupied: slot.Occupied,
                                                                            disabled: !isSlotAvailableForDate(dateStr, slot)
                                                                            }" @@click="toggleTimeSlotForDate(dateStr, slot)">
                                                                            <div class="slot-time">
                                                                                <strong>{{ slot.Name || '時段' }}</strong>
                                                                                <div class="text-muted small">{{ slot.StartTime.slice(0,5) }} - {{ slot.EndTime.slice(0,5) }}</div>
                                                                            </div>
                                                                            <div class="slot-price">
                                                                                <span v-if="selectedRoom && selectedRoom.BookingSettings === 3">免費</span>
                                                                                <span v-else-if="slot.Occupied">已預約</span>
                                                                                <span v-else>
