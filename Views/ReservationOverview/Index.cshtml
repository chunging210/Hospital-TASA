<link rel="stylesheet" href="/css/reservation.css">

<div id="app" v-cloak class="main-content">
    <div class="page-content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <!-- Header -->
                        <div class="card-header mx-4 mt-3">
                            <div class="row align-items-center">
                                <div class="col-xl-auto col-sm-12 text-branding align-middle">
                                    <span class="material-icons">playlist_add_check</span> 預約總覽
                                </div>
                                <div class="col-xl-3 col-sm-12">
                                    <div class="search-box">
                                        <div class="position-relative">
                                            <input type="text" class="form-control" v-model="searchQuery"
                                                   placeholder="搜尋預約單號、預約者...">
                                            <span class="material-icons search-icon">search</span>
                                        </div>
                                    </div>
                                </div>
                                @* <div class="col-xl-2 col-sm-10">
                                    <input type="text" class="form-control" v-model="dateRange" placeholder="選擇日期範圍" />
                                </div> *@
                                <template v-if="activeTab === 'all' && canViewAllReservations">
                                    <div class="col-xl-2 col-sm-12">
                                        <select class="form-select" v-model.number="approvalStatusFilter">
                                            <option value="">審核狀態</option>
                                            <option :value="1">待審核</option>
                                            <option :value="2">待繳費</option>
                                            <option :value="3">預約成功</option>
                                            <option :value="4">審核拒絕</option>
                                            <option :value="5">已取消</option>
                                        </select>
                                    </div>
                                    <div class="col-xl-2 col-sm-12">
                                        <select class="form-select" v-model="paymentStatusFilter">
                                            <option value="">付款狀態</option>
                                            <option :value="1">未付款</option>
                                            <option :value="2">待查帳</option>
                                            <option :value="3">已收款</option>
                                            <option :value="4">待重新上傳</option>
                                            <option value="overdue">逾期未繳</option>
                                        </select>
                                    </div>
                                </template>

                                <!-- ✅ 個人預約:單一狀態篩選 -->
                                <template v-if="activeTab === 'personal'">
                                    <div class="col-xl-2 col-sm-12">
                                        <select class="form-select" v-model="userStatusFilter">
                                            <option v-for="opt in userStatusOptions" :key="opt.value"
                                                    :value="opt.value">
                                                {{ opt.text }}
                                            </option>
                                        </select>
                                    </div>
                                </template>
                            </div>
                        </div>

                        <!-- Body -->
                        <div class="card-body">
                            <!-- Tabs -->
                            <ul class="nav nav-tabs" role="tablist">
                                <li class="nav-item" role="presentation" v-if="canViewAllReservations">
                                    <button class="nav-link" :class="{ active: activeTab === 'all' }"
                                        @@click="switchTab('all')" type="button">
                                        所有預約
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" :class="{ active: activeTab === 'personal' }"
                                        @@click="switchTab('personal')" type="button">
                                        個人預約
                                    </button>
                                </li>
                            </ul>

                            <div class="table-responsive mx-3 mt-4">
                                <!-- Tab Content -->
                                <div class="tab-content">
                                    <!-- 所有預約 Tab -->
                                    <div v-show="activeTab === 'all' && canViewAllReservations">
                                        <table class="table align-middle table-nowrap mb-0 table-hover">
                                            <thead class="table-light">
                                                <tr>
                                                    <th class="align-middle">預約單號</th>
                                                    <th class="align-middle">預約者</th>
                                                    <th class="align-middle">會議名稱</th>
                                                    <th class="align-middle">承辦單位</th>
                                                    <th class="align-middle">會議主席</th>
                                                    <th class="align-middle">預約日期</th>
                                                    <th class="align-middle">會議室</th>
                                                    <th class="align-middle">繳費截止日</th>
                                                    <th class="align-middle">付款方式</th>
                                                    <th class="align-middle">金額</th>
                                                    <th class="align-middle">審核狀態</th>
                                                    <th class="align-middle">付款狀態</th>
                                                    <th class="align-middle">成本中心代碼</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr v-for="item in filteredAllReservations" :key="item.id"
                                                    class="row-click" role="button" @@click="openDetailDrawer(item)">
                                                    <td>{{ item.reservationNo }}</td>
                                                    <td>{{ item.reserverName }}</td>
                                                    <td class="text-ellipsis">{{ item.conferenceName || '-' }}</td>
                                                    <td>{{ item.organizerUnit || '-' }}</td>
                                                    <td>{{ item.chairman || '-' }}</td>
                                                    <td>{{ item.reservationDate }}</td>
                                                    <td>{{ item.roomName }}</td>
                                                    <td>{{ item.paymentDeadline }}</td>
                                                    <td>{{ getPaymentMethodText(item.paymentMethod) }}</td>
                                                    <td>NT${{ item.amount.toLocaleString() }}</td>
                                                    <td>
                                                        <span class="badge"
                                                              :class="getApprovalStatusClass(item.approvalStatus)">
                                                            {{ item.approvalStatus }}
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <span v-if="item.paymentStatus === '-'"
                                                              class="text-muted">-</span>
                                                        <span v-else class="badge"
                                                              :class="getPaymentStatusClass(item.paymentStatus)">
                                                            {{ item.paymentStatus }}
                                                        </span>
                                                    </td>
                                                    <td>{{ item.costCenter }}</td>
                                                </tr>
                                            </tbody>


                                        </table>

                                        <page ref="allReservationsPage" @@reload="loadAllReservations"></page>

                                    </div>

                                    <!-- 個人預約 Tab -->
                                    <div v-show="activeTab === 'personal'">
                                        <!-- ✅ 批次付款工具列 -->
                                        <div v-if="selectedForBatch.length > 0" class="d-flex align-items-center gap-2 mb-2 p-2 bg-light rounded">
                                            <span class="text-secondary">已選 {{ selectedForBatch.length }} 筆，合計 NT${{ batchTotalAmount.toLocaleString() }}</span>
                                            <div class="d-flex align-items-center gap-2 ms-auto">
                                                <button v-if="batchAllCash" class="btn btn-sm btn-outline-success" @@click="downloadBatchSlip()" :disabled="batchSlipLoading">
                                                    <i class="mdi mdi-file-download-outline me-1"></i>
                                                    <span v-if="batchSlipLoading">產生中...</span>
                                                    <span v-else>下載合併繳費通知單</span>
                                                </button>
                                                <button class="btn btn-sm btn-primary" @@click="openBatchPayDrawer()">
                                                    付款
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary" @@click="clearBatchSelection()">
                                                    取消選取
                                                </button>
                                            </div>
                                        </div>
                                        <div class="table-responsive">
                                            <table class="table align-middle table-nowrap mb-0 table-hover">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th class="align-middle" style="width:40px"></th>
                                                        <th class="align-middle">預約單號</th>
                                                        <th class="align-middle">會議名稱</th>
                                                        <th class="align-middle">承辦單位</th>
                                                        <th class="align-middle">會議主席</th>
                                                        <th class="align-middle">預約日期</th>
                                                        <th class="align-middle">會議室</th>
                                                        <th class="align-middle">繳費截止日</th>
                                                        <th class="align-middle">付款方式</th>
                                                        <th class="align-middle">金額</th>
                                                        <th class="align-middle">成本中心代碼</th>
                                                        <th class="align-middle">狀態</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr v-for="item in filteredPersonalReservations" :key="item.id"
                                                        class="row-click" role="button"
                                                        :class="{ 'batch-row-disabled': isBatchPayable(item) && !isBatchSelected(item) && !isBatchCompatible(item) }"
                                                        @@click="openDetailDrawer(item)">
                                                        <td @@click.stop>
                                                            <template v-if="isBatchPayable(item)">
                                                                <input type="checkbox"
                                                                       class="form-check-input"
                                                                       :checked="isBatchSelected(item)"
                                                                       :disabled="!isBatchSelected(item) && !isBatchCompatible(item)"
                                                                       :title="!isBatchSelected(item) && !isBatchCompatible(item) ? '付款方式或管理人不同，無法合併' : ''"
                                                                       @@change="toggleBatchSelect(item, $event)" />
                                                            </template>
                                                        </td>
                                                        <td>{{ item.reservationNo }}</td>
                                                        <td class="text-ellipsis">{{ item.conferenceName || '-' }}</td>
                                                        <td>{{ item.organizerUnit || '-' }}</td>
                                                        <td>{{ item.chairman || '-' }}</td>
                                                        <td>{{ item.reservationDate }}</td>
                                                        <td>{{ item.roomName }}</td>
                                                        <td>{{ item.paymentDeadline }}</td>
                                                        <td>{{ getPaymentMethodText(item.paymentMethod) }}</td>
                                                        <td>NT${{ item.amount.toLocaleString() }}</td>
                                                        <td>{{ item.costCenter }}</td>
                                                        <td>
                                                            <!-- ✅ 使用者友善狀態 -->
                                                            <span class="badge"
                                                                  :class="getUserFriendlyStatusClass(item)">
                                                                {{ getUserFriendlyStatus(item) }}
                                                            </span>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>

                                            <page ref="personalReservationsPage" @@reload="loadPersonalReservations">
                                            </page>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ✅ 預約詳情 Offcanvas -->
    <div class="offcanvas offcanvas-end offcanvas-large" tabindex="-1" id="bookingDrawer" ref="bookingDrawer">
        <div class="offcanvas-header d-flex align-items-center justify-content-between">
            <h4 class="mb-0 fw-bold">
                預約詳情 <small class="text-muted ms-2">#{{ selectedItem?.reservationNo }}</small>
            </h4>
            <span v-if="selectedItem?.approvalStatus === '已取消'" class="text-muted ms-auto me-3" style="font-size:0.85rem;">
                <i class="mdi mdi-cancel me-1"></i><template v-if="selectedItem.cancelledByName">由 {{ selectedItem.cancelledByName }} 取消</template><template v-else>已取消</template><span v-if="selectedItem.cancelledAt"> · {{ selectedItem.cancelledAt }}</span><span v-if="selectedItem.cancelledReason"> · {{ selectedItem.cancelledReason }}</span>
            </span>
            <!-- ✅ 管理員操作按鈕區（所有預約） -->
            <div v-if="activeTab === 'all' && (canAdminEdit(selectedItem) || canAdminCancel(selectedItem))" class="">
                <div class="d-flex flex-wrap gap-2">
                    <!-- 編輯按鈕（待審核狀態） -->
                    <button type="button" class="btn btn-outline-primary" v-if="canAdminEdit(selectedItem)"
                        @@click="editReservation(selectedItem)">
                        <i class="mdi mdi-pencil me-1"></i> 編輯預約
                    </button>
                    <button type="button" class="btn btn-outline-danger" v-if="canAdminCancel(selectedItem)"
                        @@click="confirmAdminCancel(selectedItem)">
                        <i class="mdi mdi-close-circle me-1"></i> 取消預約
                    </button>
                </div>
            </div>

            <!-- ✅ 個人操作按鈕區（個人預約） -->
            <div v-if="activeTab === 'personal' && (canCancel(selectedItem) || selectedItem?.approvalStatus === '待繳費')" class="">

                <!-- 按鈕區 -->
                <div class="d-flex flex-wrap gap-2">
                    <!-- 下載繳費通知單按鈕（待繳費狀態） -->
                    <button v-if="selectedItem?.approvalStatus === '待繳費' && selectedItem?.paymentMethod === 'cash'"
                            class="btn btn-outline-success"
                            :disabled="singleSlipLoading"
                            @@click="downloadSingleSlip(selectedItem)">
                        <i class="mdi mdi-file-download-outline me-1"></i>
                        <span v-if="singleSlipLoading">產生中...</span>
                        <span v-else>下載繳費通知單</span>
                    </button>
                    <!-- 取消預約按鈕 -->
                    <button type="button" class="btn btn-outline-danger" v-if="canCancel(selectedItem)"
                        @@click="confirmCancel(selectedItem)">
                        <i class="mdi mdi-close-circle me-1"></i> 取消預約
                    </button>
                    <!-- 刪除按鈕（已停用）
                    <button type="button" class="btn btn-outline-secondary" v-if="canDelete(selectedItem)"
                        @@click="confirmDelete(selectedItem)">
                        <i class="mdi mdi-delete me-1"></i> 刪除預約
                    </button>
                    -->
                </div>
            </div>
        </div>
       
        <div class="offcanvas-body" v-if="selectedItem">
            
            <form class="row g-3">
                <!-- ========== 基本資訊 ========== -->
                    <div class="col-12">
                        <h5 class="d-flex align-items-center text-primary border-bottom">
                            <span class="material-icons icons">error_outline</span>
                            基本資訊
                        </h5>
                    </div>
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">預約者</span>
                                <label class="form-label fw-bold">{{ selectedItem.reserverName }}</label>
                            </div>
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">承辦單位</span>
                                <label class="form-label fw-bold">{{ selectedItem.organizerUnit || '-' }}</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">聯絡電話</span>
                                <label class="form-label fw-bold">{{ selectedItem.contactPhone || '-' }}</label>
                            </div>
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">電子郵件</span>
                                <label class="form-label fw-bold">{{ selectedItem.contactEmail || '-' }}</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">會議名稱</span>
                                <label class="form-label fw-bold">{{ selectedItem.conferenceName }}</label>
                            </div>
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">會議主席</span>
                                <label class="form-label fw-bold">{{ selectedItem.chairman || '-' }}</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12" v-if="selectedItem.expectedAttendees">
                        <div class="row">
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">預計人數</span>
                                <label class="form-label fw-bold">{{ selectedItem.expectedAttendees }} 人</label>
                            </div>
                        </div>
                    </div>
                    <!-- 會議內容 -->
                    <div class="col-md-12" v-if="selectedItem.description">
                        <div class="row">
                            <div class="col-md-12 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">會議內容</span>
                                <label class="form-label fw-bold" style="white-space: pre-wrap;">{{ selectedItem.description }}</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <h5 class="d-flex align-items-center text-primary border-bottom">
                            <span class="material-icons icons">access_time</span>
                            時間與地點
                        </h5>
                    </div>
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">預約日期</span>
                                <label class="form-label fw-bold">{{ selectedItem.reservationDate }}</label>
                            </div>
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">時間</span>
                                <label class="form-label fw-bold">{{ selectedItem.timeSlot || '-' }}</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-12  d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">會議室</span>
                                <label class="form-label fw-bold">{{ selectedItem.roomName }}</label>
                            </div>
                        </div>
                    </div>

                    <!-- 加租項目（設備、攤位、小型攤位、停車券、附件） -->
                    <template v-if="selectedItem.equipments?.length > 0 || selectedItem.booths?.length > 0 || selectedItem.smallBooths?.length > 0 || selectedItem.parkingTicketCount > 0 || selectedItem.attachments?.length > 0">
                        <div class="col-12">
                            <h5 class="d-flex align-items-center text-primary border-bottom">
                                <span class="material-icons icons">inventory_2</span>
                                加租項目與附件
                            </h5>
                        </div>
                        <!-- 加租設備 + 攤位加租 (同一行) -->
                        <div class="col-md-12" v-if="selectedItem.equipments?.length > 0 || selectedItem.booths?.length > 0">
                            <div class="row">
                                <div class="col-md-6 d-flex flex-sm-column" v-if="selectedItem.equipments?.length > 0">
                                    <span class="form-label text-secondary font-size-18">加租設備</span>
                                    <label class="form-label fw-bold">{{ selectedItem.equipments.join('、') }}</label>
                                </div>
                                <div class="col-md-6 d-flex flex-sm-column" v-if="selectedItem.booths?.length > 0">
                                    <span class="form-label text-secondary font-size-18">攤位加租</span>
                                    <label class="form-label fw-bold">{{ selectedItem.booths.join('、') }}</label>
                                </div>
                            </div>
                        </div>
                        <!-- 小型攤位 -->
                        <div class="col-md-12" v-if="selectedItem.smallBooths?.length > 0">
                            <div class="row">
                                <div class="col-md-6 d-flex flex-sm-column">
                                    <span class="form-label text-secondary font-size-18">小型攤位</span>
                                    <label class="form-label fw-bold">{{ selectedItem.smallBooths.join('、') }}</label>
                                </div>
                            </div>
                        </div>
                        <!-- 停車券 -->
                        <div class="col-md-12" v-if="selectedItem.parkingTicketCount > 0">
                            <div class="row">
                                <div class="col-md-6 d-flex flex-sm-column">
                                    <span class="form-label text-secondary font-size-18">停車券</span>
                                    <label class="form-label fw-bold">{{ selectedItem.parkingTicketCount }} 張</label>
                                </div>
                            </div>
                        </div>
                        <!-- 議程表 + 會議文件 (同一行) -->
                        <div class="col-md-12" v-if="selectedItem.attachments?.filter(a => a.Type === 'agenda').length > 0 || selectedItem.attachments?.filter(a => a.Type === 'document').length > 0">
                            <div class="row">
                                <div class="col-md-6 d-flex flex-sm-column" v-if="selectedItem.attachments?.filter(a => a.Type === 'agenda').length > 0">
                                    <span class="form-label text-secondary font-size-18">議程表</span>
                                    <div>
                                        <template v-for="(att, idx) in selectedItem.attachments.filter(a => a.Type === 'agenda')" :key="att.Id">
                                            <a :href="att.FilePath" target="_blank" class="me-2">附件{{ idx + 1 }}</a>
                                        </template>
                                    </div>
                                </div>
                                <div class="col-md-6 d-flex flex-sm-column" v-if="selectedItem.attachments?.filter(a => a.Type === 'document').length > 0">
                                    <span class="form-label text-secondary font-size-18">會議文件</span>
                                    <div>
                                        <template v-for="(att, idx) in selectedItem.attachments.filter(a => a.Type === 'document')" :key="att.Id">
                                            <a :href="att.FilePath" target="_blank" class="me-2">附件{{ idx + 1 }}</a>
                                        </template>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </template>

                    <div class="col-12">
                        <h5 class="d-flex align-items-center text-primary border-bottom">
                            <span class="material-icons icons">local_atm</span>
                            付款資訊
                        </h5>
                    </div>
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">付款方式</span>
                                <label class="form-label fw-bold">{{ getPaymentMethodText(selectedItem.paymentMethod)
                                    }}</label>
                            </div>
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">金額</span>
                                <label class="form-label fw-bold">NT${{ selectedItem.amount?.toLocaleString() }}</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">繳費截止日</span>
                                <label class="form-label fw-bold">{{ selectedItem.paymentDeadline }}</label>
                            </div>
                            <div class="col-md-6 d-flex flex-sm-column">
                                <span class="form-label text-secondary font-size-18">成本中心代碼</span>
                                <label class="form-label fw-bold">{{ selectedItem.costCenter || '-' }}</label>
                            </div>
                        </div>
                    </div>
                    <!-- 付款聯絡資訊 -->
                    <div class="col-md-12" v-if="selectedItem.paymentContactInfo">
                        <div class="alert alert-light border mb-0 py-2">
                            <small class="text-muted">
                                <i class="mdi mdi-information-outline me-1"></i>
                                {{ selectedItem.paymentContactInfo }}
                            </small>
                        </div>
                    </div>

                    <!-- ✅ 已上傳付款憑證 -->
                    <div class="col-md-12" v-if="selectedItem.paymentFilePath">
                        <div class="row">
                            <div class="col-12">
                                <span class="form-label text-secondary font-size-18">已上傳憑證</span>
                                <div class="mt-1">
                                    <a :href="selectedItem.paymentFilePath" target="_blank">
                                        <img :src="selectedItem.paymentFilePath"
                                             style="max-width:220px;max-height:180px;border-radius:8px;border:1px solid #dee2e6;object-fit:contain;background:#f8f9fa;"
                                             :alt="selectedItem.paymentFileName">
                                    </a>
                                    <div class="small text-muted mt-1">{{ selectedItem.paymentFileName }}</div>
                                    <div v-if="selectedItem.paymentNote" class="small text-secondary mt-1">備註：{{ selectedItem.paymentNote }}</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ✅ 已上傳優惠證明 -->
                    <div class="col-md-12" v-if="selectedItem.discountProofPath">
                        <div class="row">
                            <div class="col-12">
                                <span class="form-label text-secondary font-size-18">已上傳優惠證明</span>
                                <div class="mt-1">
                                    <a :href="selectedItem.discountProofPath" target="_blank">
                                        <img :src="selectedItem.discountProofPath"
                                             style="max-width:220px;max-height:180px;border-radius:8px;border:1px solid #dee2e6;object-fit:contain;background:#f8f9fa;"
                                             :alt="selectedItem.discountProofName">
                                    </a>
                                    <div class="small text-muted mt-1">{{ selectedItem.discountProofName }}</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ✅ 折扣資訊 -->
                    <div class="col-md-12" v-if="selectedItem.discountAmount">
                        <div class="d-flex align-items-center justify-content-between px-3 py-2 rounded"
                             style="background:#f0faf4; border-left:3px solid #28a745;">
                            <span class="text-secondary font-size-18">
                                <i class="mdi mdi-sale me-1"></i>折扣金額
                                <span v-if="selectedItem.discountReason" class="ms-1 text-muted">（{{ selectedItem.discountReason }}）</span>
                            </span>
                            <span class="fw-bold text-success">- NT${{ selectedItem.discountAmount?.toLocaleString() }}</span>
                        </div>
                    </div>

                    <!-- ✅ 審核歷程（水平步驟進度條） -->
                    <template v-if="selectedItem.approvalHistory?.length > 0">
                        <div class="col-12">
                            <h5 class="d-flex align-items-center text-primary border-bottom mb-0 approval-header"
                                role="button" @@click="approvalHistoryExpanded = !approvalHistoryExpanded">
                                <span class="material-icons icons">fact_check</span>
                                審核歷程
                                <span class="ms-2 badge" :class="getProgressBadgeClass(selectedItem.approvalHistory)">
                                    {{ getApprovalProgress(selectedItem.approvalHistory) }}
                                </span>
                                <span class="material-icons ms-auto expand-icon" :class="{ 'rotated': approvalHistoryExpanded }">
                                    expand_more
                                </span>
                            </h5>
                        </div>
                        <!-- 展開的水平步驟 -->
                        <div class="col-12" v-show="approvalHistoryExpanded">
                            <div>
                                <div class="steps-scroll">
                                    <div class="steps">
                                        <div v-for="(history, index) in selectedItem.approvalHistory" :key="index"
                                             class="step" :class="getStepClass(history)">
                                            <!-- 圓形節點 -->
                                            <div class="step-circle">
                                                <template v-if="history.Status === 'Approved'">✓</template>
                                                <template v-else-if="history.Status === 'Rejected'">✕</template>
                                                <template v-else>{{ history.Level }}</template>
                                            </div>
                                            <!-- 文字區 -->
                                            <div class="step-label">
                                                <div class="step-name">第 {{ history.Level }} 關</div>
                                                <div class="step-status">{{ history.StatusText }}</div>
                                                <!-- 決行/跳過標籤 -->
                                                <div v-if="selectedItem.approvalStatus === '審核拒絕' && history.Status === 'Approved'"
     class="text-danger" style="font-size:11px;">
    （審核拒絕）
</div>
                                                <span v-if="history.Reason?.includes('決行') && !history.Reason?.includes('跳過')"
                                                      class="step-tag tag-decision">決行</span>
                                                <span v-else-if="history.Reason?.includes('跳過')"
                                                      class="step-tag tag-skip">跳過</span>
                                                <!-- 審核人（僅所有預約可見） -->
                                                <template v-if="selectedItem.openedFrom === 'all' && history.ApproverName">
                                                    <div class="step-reviewer">{{ history.ApproverName }}</div>
                                                    <div v-if="history.ApprovedByName && history.ApprovedByName !== history.ApproverName"
                                                         class="step-meta">（{{ history.ApprovedByName }} 代理）</div>
                                                </template>
                                                <div v-if="history.ApprovedAt" class="step-meta">{{ history.ApprovedAt }}</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="scroll-hint" v-if="selectedItem.approvalHistory?.length > 5">
                                    ← 左右滑動查看更多 →
                                </div>
                            </div>
                            <!-- 折扣/拒絕原因（如有） -->
                            <template v-for="(history, index) in selectedItem.approvalHistory" :key="'extra-'+index">
                                <div v-if="history.DiscountAmount" class="mt-2">
                                    <small class="text-success">
                                        <i class="mdi mdi-sale me-1"></i>第{{ history.Level }}關折扣 NT${{ history.DiscountAmount?.toLocaleString() }}
                                        <span v-if="history.DiscountReason">（{{ history.DiscountReason }}）</span>
                                    </small>
                                </div>
                                <div v-if="history.Status === 'Rejected' && history.Reason" class="mt-2">
                                    <small class="text-danger">
                                        <i class="mdi mdi-message-alert me-1"></i>拒絕原因：{{ history.Reason }}
                                    </small>
                                </div>
                            </template>
                        </div>
                    </template>
                <div>
                    <div class="col-12">
                        <h5 class="d-flex align-items-center text-primary border-bottom mb-3">
                            <span class="material-icons icons">label_important_outline</span>
                            狀態資訊
                        </h5>
                    </div>
                    <template v-if="selectedItem.openedFrom === 'personal'">
                        <div class="col-md-12">
                            <div class="row">
                                <label class="form-label col-md-3 fw-bold">預約狀態</label>
                                <label class="form-label col-md-9">
                                    <span class="badge" :class="getUserFriendlyStatusClass(selectedItem)">
                                        {{ getUserFriendlyStatus(selectedItem) }}
                                    </span>
                                </label>
                            </div>
                        </div>

                        <!-- 審核拒絕原因 -->
                        <div class="col-md-12" v-if="selectedItem.approvalStatus === '審核拒絕' && selectedItem.rejectReason">
                            <div class="alert alert-danger" role="alert">
                                <strong><i class="mdi mdi-alert-circle me-2"></i>拒絕原因:</strong>
                                <p class="mb-0 mt-2">{{ selectedItem.rejectReason }}</p>
                            </div>
                        </div>

                        <!-- 付款憑證拒絕原因 -->
                        <div class="col-md-12"
                             v-if="selectedItem.paymentStatus === '待重新上傳' && selectedItem.paymentRejectReason">
                            <div class="alert alert-warning" role="alert">
                                <strong><i class="mdi mdi-alert me-2"></i>需要重新上傳:</strong>
                                <p class="mb-0 mt-2">{{ selectedItem.paymentRejectReason }}</p>
                            </div>
                        </div>
                </template>

                <template v-if="selectedItem.openedFrom === 'all'">
                        <div class="col-md-12">
                            <div class="row">
                                <label class="form-label col-md-3 fw-bold">審核狀態</label>
                                <label class="form-label col-md-9">
                                    <span class="badge" :class="getApprovalStatusClass(selectedItem.approvalStatus)">
                                        {{ selectedItem.approvalStatus }}
                                    </span>
                                </label>
                            </div>
                        </div>

                        <!-- 審核拒絕原因 -->
                        <div class="col-md-12" v-if="selectedItem.approvalStatus === '審核拒絕' && selectedItem.rejectReason">
                            <div class="alert alert-danger" role="alert">
                                <strong><i class="mdi mdi-alert-circle me-2"></i>拒絕原因:</strong>
                                <p class="mb-0 mt-2">{{ selectedItem.rejectReason }}</p>
                            </div>
                        </div>

                        <div class="col-md-12 mt-2">
                            <div class="row">
                                <label class="form-label col-md-3 fw-bold">付款狀態</label>
                                <label class="form-label col-md-9">
                                    <span v-if="selectedItem.paymentStatus === '-'" class="text-muted">-</span>
                                    <span v-else class="badge" :class="getPaymentStatusClass(selectedItem.paymentStatus)">
                                        {{ selectedItem.paymentStatus }}
                                    </span>
                                </label>
                            </div>
                        </div>

                        <!-- 付款憑證拒絕原因 -->
                        <div class="col-md-12"
                             v-if="selectedItem.paymentStatus === '待重新上傳' && selectedItem.paymentRejectReason">
                            <div class="alert alert-warning" role="alert">
                                <strong><i class="mdi mdi-alert me-2"></i>付款憑證問題:</strong>
                                <p class="mb-0 mt-2">{{ selectedItem.paymentRejectReason }}</p>
                            </div>
                        </div>
                </template>
                </div>

            </form>

            </div>
        </div>

    </div>

    <!-- ✅ 合併付款 Offcanvas -->
    <div class="offcanvas offcanvas-end offcanvas-large" tabindex="-1" id="batchPayDrawer">
        <div class="offcanvas-header d-flex align-items-center justify-content-between">
            <h4 class="mb-0 fw-bold">合併付款</h4>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <!-- ✅ 我的待上傳通知單 -->
            <div v-if="myDraftOrders.length > 0" class="mb-4">
                <h6 class="text-secondary border-bottom pb-1 mb-2">
                    <i class="mdi mdi-file-clock-outline me-1"></i>我的待上傳通知單
                </h6>
                <div v-for="draft in myDraftOrders" :key="draft.orderId"
                     class="border rounded p-2 mb-2" style="font-size:13px;">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="fw-semibold">編號 {{ draft.orderShortId }}</span>
                        <span class="text-muted" style="font-size:11px;">{{ draft.createdAt }}</span>
                    </div>
                    <div v-for="item in draft.items" :key="item.conferenceId" class="text-muted ps-1" style="font-size:12px;">
                        ・{{ item.conferenceName }}（{{ item.organizerUnit }}）NT${{ item.amount.toLocaleString() }}
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="fw-bold">合計 NT${{ draft.totalAmount.toLocaleString() }}</span>
                        <button class="btn btn-sm btn-outline-primary" @@click="loadDraftOrder(draft)">
                            載入此批次繳費
                        </button>
                    </div>
                </div>
            </div>

            <!-- 已選預約清單 -->
            <div class="mb-4">
                <h6 class="text-secondary mb-2">已選預約（{{ selectedForBatch.length }} 筆）</h6>
                <table class="table table-sm table-bordered mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>預約單號</th>
                            <th>會議名稱</th>
                            <th>日期</th>
                            <th class="text-end">金額</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="s in selectedForBatch" :key="s.id">
                            <td>{{ s.reservationNo }}</td>
                            <td class="text-ellipsis">{{ s.conferenceName }}</td>
                            <td>{{ s.reservationDate }}</td>
                            <td class="text-end">NT${{ s.amount.toLocaleString() }}</td>
                        </tr>
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td colspan="3" class="text-end">
                                合計
                                <span v-if="batchPayMode === 'counter'" class="text-muted fw-normal ms-1" style="font-size:13px;">（含5%營業稅 NT${{ batchTaxAmount.toLocaleString() }}）</span>
                            </td>
                            <td class="text-end">NT${{ batchPayMode === 'counter' ? batchGrandTotal.toLocaleString() : batchTotalAmount.toLocaleString() }}</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <!-- 臨櫃付款表單 -->
            <template v-if="batchPayMode === 'counter'">
                <h6 class="text-secondary border-bottom pb-1 mb-3">臨櫃付款</h6>
                <div class="mb-3">
                    <label class="form-label">上傳三聯單 <span class="text-danger">*</span></label>
                    <input type="file" class="form-control" ref="batchPayFiles" accept="image/*,.pdf" multiple />
                </div>
                <div class="mb-3">
                    <label class="form-label">備註</label>
                    <textarea class="form-control" v-model="batchPayForm.counterNote" rows="2"></textarea>
                </div>
                <button class="btn btn-primary w-100" @@click="submitBatchCounter()">送出</button>
            </template>

            <!-- 匯款表單 -->
            <template v-if="batchPayMode === 'transfer'">
                <h6 class="text-secondary border-bottom pb-1 mb-3">銀行匯款</h6>
                <div class="mb-3">
                    <label class="form-label">轉帳末五碼 <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" v-model="batchPayForm.last5"
                           maxlength="5" placeholder="請輸入末五碼" />
                </div>
                <div class="mb-3">
                    <label class="form-label">轉帳金額 <span class="text-danger">*</span></label>
                    <input type="number" class="form-control" v-model.number="batchPayForm.amount" />
                </div>
                <div class="mb-3">
                    <label class="form-label">轉帳時間</label>
                    <input type="datetime-local" class="form-control" v-model="batchPayForm.transferAt" />
                </div>
                <div class="mb-3">
                    <label class="form-label">匯款截圖</label>
                    <input type="file" class="form-control" ref="batchTransferFile" accept="image/*,.pdf" />
                </div>
                <div class="mb-3">
                    <label class="form-label">備註</label>
                    <textarea class="form-control" v-model="batchPayForm.transferNote" rows="2"></textarea>
                </div>
                <button class="btn btn-primary w-100" @@click="submitBatchTransfer()">送出</button>
            </template>
        </div>
    </div>

    <!-- ✅ 取消預約 Modal -->
    <div class="modal fade" id="cancelReasonModal" tabindex="-1" ref="cancelReasonModal">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-body pt-4 px-4 pb-3">
                    <p class="mb-2 fw-semibold">確認取消預約？</p>
                    <p class="text-muted small mb-3" v-if="cancelModal.warning">{{ cancelModal.warning }}</p>
                    <textarea class="form-control form-control-sm" v-model="cancelModal.reason" rows="2"
                              placeholder="取消原因（選填）"></textarea>
                </div>
                <div class="modal-footer border-0 pt-0 px-4 pb-3 gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">返回</button>
                    <button type="button" class="btn btn-sm btn-danger ms-auto" @@click="cancelModal.submit()">確認取消</button>
                </div>
            </div>
        </div>
    </div>