@section head {
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
}

@section script {
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
}

<div class="page-content" v-cloak>
    <div class="container-fluid">

        <div class="card border-0 shadow-sm">

            <!-- Card Header：左側標題 + 中間 Tab + 右側新增按鈕 -->
            <div class="card-header px-4 pt-3 pb-0 d-flex align-items-end justify-content-between">
                <ul class="nav nav-tabs border-0">
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-1"
                           :class="{ active: tab === 'announcement' }"
                           @@click.prevent="tab = 'announcement'" href="#">
                            <span class="material-icons" style="font-size:18px;">campaign</span>
                            公告管理
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-1"
                           :class="{ active: tab === 'quicklink' }"
                           @@click.prevent="tab = 'quicklink'" href="#">
                            <span class="material-icons" style="font-size:18px;">link</span>
                            超連結
                        </a>
                    </li>
                </ul>
                <div class="pb-2">
                    <button v-if="tab === 'announcement'" class="btn btn-primary btn-sm" @@click="openCreate">
                        <span class="material-icons" style="font-size:16px;vertical-align:middle;">add</span>
                        新增公告
                    </button>
                    <button v-else class="btn btn-primary btn-sm" @@click="openLinkCreate">
                        <span class="material-icons" style="font-size:16px;vertical-align:middle;">add</span>
                        新增連結
                    </button>
                </div>
            </div>

            <!-- Card Body -->
            <div class="card-body p-4">

                <!-- ══════════ 公告管理 ══════════ -->
                <div v-show="tab === 'announcement'">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>標題</th>
                                    <th class="text-center" style="width:60px;white-space:nowrap;">置頂</th>
                                    <th class="text-center" style="width:80px;white-space:nowrap;">預設展開</th>
                                    <th class="text-center" style="width:70px;white-space:nowrap;">狀態</th>
                                    <th style="width:100px;white-space:nowrap;">到期日</th>
                                    <th class="text-center" style="width:50px;white-space:nowrap;">附件</th>
                                    <th style="width:140px;white-space:nowrap;">建立時間</th>
                                    <th style="width:110px;white-space:nowrap;">操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-if="loading">
                                    <td colspan="8" class="text-center py-4">
                                        <div class="spinner-border spinner-border-sm text-primary"></div>
                                    </td>
                                </tr>
                                <tr v-else-if="list.length === 0">
                                    <td colspan="8" class="text-center text-muted py-4">尚無公告</td>
                                </tr>
                                <tr v-for="item in list" :key="item.Id">
                                    <td style="min-width:150px;word-break:break-word;">
                                        <span v-if="item.IsPinned" class="badge bg-warning text-dark me-1">置頂</span>
                                        {{ item.Title }}
                                    </td>
                                    <td class="text-center">
                                        <span class="material-icons" :class="item.IsPinned ? 'text-warning' : 'text-muted'">
                                            {{ item.IsPinned ? 'push_pin' : 'remove' }}
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="material-icons" :class="item.IsDefaultExpanded ? 'text-primary' : 'text-muted'">
                                            {{ item.IsDefaultExpanded ? 'expand_circle_down' : 'remove' }}
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="material-icons" :class="item.IsActive ? 'text-success' : 'text-muted'" style="font-size:20px;">
                                            {{ item.IsActive ? 'check_circle' : 'remove_circle_outline' }}
                                        </span>
                                    </td>
                                    <td style="white-space:nowrap;">{{ item.EndDate || '永久' }}</td>
                                    <td class="text-center">{{ item.AttachmentCount }}</td>
                                    <td style="white-space:nowrap;">{{ item.CreateAt }}</td>
                                    <td style="white-space:nowrap;">
                                        <button class="btn btn-outline-primary btn-sm me-1" @@click="openEdit(item.Id)">編輯</button>
                                        <button class="btn btn-outline-danger btn-sm" @@click="deleteAnn(item.Id, item.Title)">刪除</button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- ══════════ 超連結 ══════════ -->
                <div v-show="tab === 'quicklink'">
                    <div class="text-muted small mb-2">
                        <span class="material-icons" style="font-size:14px;vertical-align:middle;">drag_indicator</span>
                        拖移左側圖示可調整順序
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:32px;"></th>
                                    <th style="width:150px;white-space:nowrap;">顯示文字</th>
                                    <th>網址</th>
                                    <th style="width:110px;white-space:nowrap;">操作</th>
                                </tr>
                            </thead>
                            <tbody id="linkSortable">
                                <tr v-if="links.length === 0">
                                    <td colspan="5" class="text-center text-muted py-4">尚無連結</td>
                                </tr>
                                <tr v-for="link in links" :key="link.Id" :data-id="link.Id">
                                    <td class="text-muted link-drag-handle" style="cursor:grab;">
                                        <span class="material-icons" style="font-size:20px;">drag_indicator</span>
                                    </td>
                                    <td style="word-break:break-word;">{{ link.Title }}</td>
                                    <td style="word-break:break-all;">
                                        <a :href="link.Url" target="_blank">{{ link.Url }}</a>
                                    </td>
                                    <td style="white-space:nowrap;">
                                        <button class="btn btn-outline-primary btn-sm me-1" @@click="openLinkEdit(link.Id, link.Title, link.Url)">編輯</button>
                                        <button class="btn btn-outline-danger btn-sm" @@click="deleteLink(link.Id, link.Title)">刪除</button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<!-- ══════════ 公告 Modal ══════════ -->
<div class="modal fade" id="annModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{form.id ? '編輯公告' : '新增公告' }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- 標題 -->
                <div class="mb-3">
                    <label class="form-label">標題 <span class="text-danger">*</span></label>
                    <input v-model="form.title" type="text" class="form-control" maxlength="200">
                </div>
                <!-- 內容 -->
                <div class="mb-3">
                    <label class="form-label">內容 <span class="text-danger">*</span></label>
                    <div id="quillEditor" style="height: 350px;"></div>
                </div>
                <!-- 附件區 -->
                <div class="mb-3">
                    <label class="form-label">附件
                        <small class="text-muted fw-normal ms-1">（圖片 / PDF / Word / Excel / PPT / ZIP，最大 50MB）</small>
                    </label>
                    <div class="border rounded p-3">
                        <label class="btn btn-outline-secondary btn-sm mb-2" :class="{ disabled: uploading }">
                            <span v-if="uploading" class="spinner-border spinner-border-sm me-1"></span>
                            <span class="material-icons" style="font-size:16px;vertical-align:middle;" v-else>upload_file</span>
                            上傳附件
                            <input type="file" accept=".jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.zip,.rar,.txt" style="display:none" @@change="uploadFile">
                        </label>
                        <!-- 新增模式：顯示待上傳清單 -->
                        <template v-if="!form.id">
                            <div v-if="pendingFiles.length === 0" class="text-muted small">尚無附件</div>
                            <div v-for="(f, idx) in pendingFiles" :key="idx"
                                 class="d-flex align-items-center gap-2 py-1 border-top">
                                <span class="material-icons text-muted" style="font-size:18px;">insert_drive_file</span>
                                <span class="flex-grow-1 text-truncate">{{ f.name }}</span>
                                <button class="btn btn-outline-danger btn-sm py-0 flex-shrink-0" @@click="removePending(idx)">移除</button>
                            </div>
                        </template>
                        <!-- 編輯模式：顯示已上傳清單 -->
                        <template v-else>
                            <div v-if="form.attachments.length === 0" class="text-muted small">尚無附件</div>
                            <div v-for="att in form.attachments" :key="att.id"
                                 class="d-flex align-items-center gap-2 py-1 border-top">
                                <span class="material-icons text-muted" style="font-size:18px;">{{ fileIcon(att.fileType) }}</span>
                                <a :href="att.url" target="_blank" class="flex-grow-1 text-truncate">{{ att.fileName }}</a>
                                <button class="btn btn-outline-danger btn-sm py-0 flex-shrink-0" @@click="deleteAttachment(att.id)">刪除</button>
                            </div>
                        </template>
                    </div>
                </div>
                <!-- 底部：到期日 + 選項 -->
                <div class="d-flex align-items-center gap-4 flex-wrap pt-1">
                    <div class="d-flex align-items-center gap-2">
                        <label class="text-muted small mb-0" style="white-space:nowrap;">到期日</label>
                        <input v-model="form.endDate" type="date" class="form-control form-control-sm" style="width:150px;">
                        <small class="text-muted" style="white-space:nowrap;">不填為永久</small>
                    </div>
                    <div class="d-flex align-items-center gap-3 ms-auto">
                        <div class="form-check mb-0">
                            <input v-model="form.isPinned" class="form-check-input" type="checkbox" id="chkPinned">
                            <label class="form-check-label small" for="chkPinned">置頂</label>
                        </div>
                        <div class="form-check mb-0">
                            <input v-model="form.isDefaultExpanded" class="form-check-input" type="checkbox" id="chkDefaultExpanded">
                            <label class="form-check-label small" for="chkDefaultExpanded">預設展開</label>
                        </div>
                        <div class="form-check mb-0">
                            <input v-model="form.isActive" class="form-check-input" type="checkbox" id="chkActive">
                            <label class="form-check-label small" for="chkActive">啟用</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" @@click="saveAnn" :disabled="saving">
                    <span v-if="saving" class="spinner-border spinner-border-sm me-1"></span>
                    儲存
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ══════════ 超連結 Modal ══════════ -->
<div class="modal fade" id="linkModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ linkForm.id ? '編輯連結' : '新增連結' }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">顯示文字 <span class="text-danger">*</span></label>
                    <input v-model="linkForm.title" type="text" class="form-control" maxlength="100" placeholder="例：公司官網">
                </div>
                <div class="mb-3">
                    <label class="form-label">網址 <span class="text-danger">*</span></label>
                    <input v-model="linkForm.url" type="url" class="form-control" placeholder="https://...">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" @@click="saveLink" :disabled="saving">
                    <span v-if="saving" class="spinner-border spinner-border-sm me-1"></span>
                    儲存
                </button>
            </div>
        </div>
    </div>
</div>

