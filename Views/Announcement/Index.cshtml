<div class="page-content" v-cloak>
    <div class="container-fluid">

        <!-- 公告列表 -->
        <div class="card border-0 shadow-sm">
            <div class="card-header mx-4 mt-3">
                <div class="d-flex align-items-center">
                    <span class="material-icons me-2">campaign</span>
                    <span class="text-branding">公告區</span>
                </div>
            </div>
            <div class="card-body p-4">

                <!-- 載入中 -->
                <div v-if="loading" class="text-center py-5">
                    <div class="spinner-border text-primary"></div>
                </div>

                <!-- 無資料 -->
                <div v-else-if="list.length === 0" class="text-center text-muted py-5">
                    <span class="material-icons" style="font-size:48px;">inbox</span>
                    <p class="mt-2">目前沒有公告</p>
                </div>

                <!-- 公告列表 -->
                <div v-else>
                    <!-- 置頂公告 -->
                    <div v-for="item in pinnedList" :key="item.Id" class="mb-2">
                        <div class="rounded border border-warning bg-warning bg-opacity-10 overflow-hidden">
                            <!-- 標題列 -->
                            <div class="d-flex align-items-center px-3 py-2"
                                 style="cursor:pointer;" @@click="toggle(item.Id)">
                                <span class="badge bg-warning text-dark me-2">置頂</span>
                                <span class="fw-semibold flex-grow-1">{{ item.Title }}</span>
                                <small class="text-muted ms-3" v-if="item.EndDate">有效至 {{ item.EndDate }}</small>
                                <span class="material-icons text-muted ms-2" style="font-size:18px;transition:transform .2s;"
                                      :style="expanded[item.Id] ? 'transform:rotate(90deg)' : ''">
                                    chevron_right
                                </span>
                            </div>
                            <!-- 展開內容 -->
                            <div v-if="expanded[item.Id]" class="px-3 pb-3 border-top border-warning border-opacity-25">
                                <div v-html="item.Content" class="announcement-content pt-3"></div>
                                <div v-if="item.Attachments && item.Attachments.length > 0" class="mt-3 pt-3 border-top">
                                    <small class="text-muted d-block mb-2">
                                        <span class="material-icons" style="font-size:16px;vertical-align:middle;">attach_file</span>
                                        附件
                                    </small>
                                    <a v-for="att in item.Attachments" :key="att.Id"
                                       :href="att.Url" target="_blank"
                                       class="btn btn-outline-secondary btn-sm me-2 mb-1">
                                        <span class="material-icons" style="font-size:14px;vertical-align:middle;">
                                            {{ fileIcon(att.FileType) }}
                                        </span>
                                        {{ att.FileName }}
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 一般公告 -->
                    <div v-for="item in normalList" :key="item.Id" class="mb-2">
                        <div class="rounded border overflow-hidden">
                            <!-- 標題列 -->
                            <div class="d-flex align-items-center px-3 py-2"
                                 style="cursor:pointer;" @@click="toggle(item.Id)">
                                <span class="flex-grow-1">{{ item.Title }}</span>
                                <small class="text-muted ms-3" v-if="item.EndDate">有效至 {{ item.EndDate }}</small>
                                <span class="material-icons text-muted ms-2" style="font-size:18px;transition:transform .2s;"
                                      :style="expanded[item.Id] ? 'transform:rotate(90deg)' : ''">
                                    chevron_right
                                </span>
                            </div>
                            <!-- 展開內容 -->
                            <div v-if="expanded[item.Id]" class="px-3 pb-3 border-top">
                                <div v-html="item.Content" class="announcement-content pt-3"></div>
                                <div v-if="item.Attachments && item.Attachments.length > 0" class="mt-3 pt-3 border-top">
                                    <small class="text-muted d-block mb-2">
                                        <span class="material-icons" style="font-size:16px;vertical-align:middle;">attach_file</span>
                                        附件
                                    </small>
                                    <a v-for="att in item.Attachments" :key="att.Id"
                                       :href="att.Url" target="_blank"
                                       class="btn btn-outline-secondary btn-sm me-2 mb-1">
                                        <span class="material-icons" style="font-size:14px;vertical-align:middle;">
                                            {{ fileIcon(att.FileType) }}
                                        </span>
                                        {{ att.FileName }}
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 快速連結 -->
                <div v-if="quickLinks.length > 0" class="mt-4 pt-4 border-top d-flex flex-wrap gap-2">
                    <a v-for="link in quickLinks" :key="link.Id" :href="link.Url" target="_blank"
                       class="btn btn-outline-primary btn-sm">
                        {{ link.Title }}
                    </a>
                </div>

            </div>
        </div>

    </div>
</div>

<style>
    .announcement-content img { max-width: 100%; }
    .announcement-content a { color: #0d6efd; }
</style>
