<input type="hidden" id="announcementId" value="@ViewBag.AnnouncementId">
<div class="page-content" v-cloak>
    <div class="container-fluid">

        <!-- 載入中 -->
        <div v-if="loading" class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>

        <!-- 找不到 -->
        <div v-else-if="!item" class="text-center text-muted py-5">
            <span class="material-icons" style="font-size:48px;">inbox</span>
            <p class="mt-2">找不到此公告</p>
            <a href="/announcement" class="btn btn-outline-secondary btn-sm">返回公告區</a>
        </div>

        <!-- 公告內容 -->
        <div v-else class="card border-0 shadow-sm">
            <div class="card-header mx-4 mt-3">
                <div class="d-flex align-items-center">
                    <span class="material-icons me-2">campaign</span>
                    <span class="text-branding">公告區</span>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="mb-3">
                    <span class="badge bg-warning text-dark me-2" v-if="item.IsPinned">置頂</span>
                    <h4 class="d-inline">{{ item.Title }}</h4>
                    <div class="text-muted mt-1" v-if="item.EndDate">
                        <small>有效至 {{ item.EndDate }}</small>
                    </div>
                </div>
                <hr>
                <div v-html="item.Content" class="announcement-content"></div>

                <!-- 附件 -->
                <div v-if="item.Attachments && item.Attachments.length > 0" class="mt-4 pt-3 border-top">
                    <small class="text-muted d-block mb-2">
                        <span class="material-icons" style="font-size:16px;vertical-align:middle;">attach_file</span>
                        附件
                    </small>
                    <a v-for="att in item.Attachments" :key="att.Id"
                       :href="att.Url" target="_blank"
                       class="btn btn-outline-secondary btn-sm me-2 mb-1">
                        <span class="material-icons" style="font-size:14px;vertical-align:middle;">
                            {{ att.FileType === 'pdf' ? 'picture_as_pdf' : 'image' }}
                        </span>
                        {{ att.FileName }}
                    </a>
                </div>

                <div class="mt-4">
                    <a href="/announcement" class="btn btn-outline-secondary btn-sm">
                        <span class="material-icons" style="font-size:16px;vertical-align:middle;">arrow_back</span>
                        返回公告區
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .announcement-content img { max-width: 100%; }
    .announcement-content a { color: #0d6efd; }
</style>
