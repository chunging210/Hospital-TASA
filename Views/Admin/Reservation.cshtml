<link rel="stylesheet" href="/css/reservation.css">
<div class="page-content" v-cloak>
    <div class="container-fluid vstack gap-3">
        <div class="card">
            <div class="card-header mx-4 mt-3">
                <div class="row d-flex align-items-center">
                    <!-- 標題 -->
                    <div class="col-xl-auto col-sm-12 text-branding d-flex align-items-center">
                        <span class="material-icons">assignment_turned_in</span>預約審核
                    </div>

                    <div class="col-12 col-lg-3">
                        <div class="search-box">
                            <div class="position-relative">
                                <input type="text" class="form-control" v-model="reservation.query.keyword"
                                       placeholder="搜尋預約單號、申請人...">
                                <span class="material-icons search-icon">search</span>
                            </div>
                        </div>
                    </div>

                    <!-- ✅ 租借審核狀態篩選 -->
                    <div class="col-12 col-lg-2" v-if="reservation.activeTab.value === 'approval'">
                        <select v-model.number="reservation.query.reservationStatus"
                                class="form-select">
                            <option :value="null">全部狀態</option>
                            <option :value="1">待審核</option>
                            <option :value="2">已核准 (待繳費)</option>
                            <option :value="4">已拒絕</option>
                        </select>
                    </div>

                    <!-- ✅ 付款審核狀態篩選 (watch 會自動觸發查詢，不需要 @@change) -->
                    <div class="col-12 col-lg-2" v-if="reservation.activeTab.value === 'payment'">
                        <select v-model="reservation.query.paymentStatus" class="form-select">
                            <option value="">全部狀態</option>
                            <option value="2">待查帳</option>
                            <option value="3">已收款</option>
                            <option value="4">待重新上傳</option>
                            <option value="overdue">逾期未繳</option>
                        </select>
                    </div>

                    <!-- ✅ 繳費方式篩選 (租借審核用，批量審核限成本分攤) -->
                    <div class="col-12 col-lg-2" v-if="reservation.activeTab.value === 'approval'">
                        <select v-model="reservation.query.paymentMethod"
                                class="form-select">
                            <option value="">繳費方式</option>
                            <option value="cost-sharing">成本分攤</option>
                            <option value="cash">現金付款</option>
                            <option value="transfer">銀行匯款</option>
                        </select>
                    </div>

                    <!-- 部門代碼篩選（只在選成本分攤時顯示） -->
                    <div class="col-12 col-lg-2 position-relative dept-search-wrap"
                         v-if="reservation.activeTab.value === 'approval' && reservation.query.paymentMethod === 'cost-sharing'">
                        <div class="input-group">
                            <input type="text" class="form-control"
                                   v-model="deptSearch.keyword.value"
                                   @@input="deptSearch.filter()"
                                   @@focus="deptSearch.showDropdown.value = true"
                                   placeholder="篩選部門代碼..." autocomplete="off">
                            <button v-if="deptSearch.keyword.value" class="btn btn-outline-secondary"
                                    type="button" @@click="deptSearch.clear(reservation.query)">
                                <span class="material-icons" style="font-size:16px;">close</span>
                            </button>
                        </div>
                        <div v-if="deptSearch.showDropdown.value && deptSearch.filtered.length > 0"
                             class="dept-dropdown">
                            <div v-for="item in deptSearch.filtered" :key="item.code"
                                 class="dept-item"
                                 @@click="deptSearch.select(item, reservation.query)">
                                <strong>{{ item.code }}</strong> - {{ item.name }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <!-- ✅ Tabs 導航 -->
                <ul class="nav nav-tabs mb-3" role="tablist">
                    <!-- 租借審核 Tab -->
                    <li class="nav-item" v-if="reservation.permissions.canApproveReservation">
                        <button class="nav-link" :class="{ active: reservation.activeTab.value === 'approval' }"
                            @@click="reservation.switchTab('approval')" type="button">
                            <span class="material-icons me-1">fact_check</span>
                            租借審核
                        </button>
                    </li>

                    <!-- 付款審核 Tab -->
                    <li class="nav-item" v-if="reservation.permissions.canApprovePayment">
                        <button class="nav-link" :class="{ active: reservation.activeTab.value === 'payment' }"
                            @@click="reservation.switchTab('payment')" type="button">
                            <span class="material-icons me-1">receipt_long</span>
                            付款審核
                        </button>
                    </li>
                </ul>

                <!-- ✅ 租借審核列表 -->
                <div v-show="reservation.activeTab.value === 'approval'">

                    <!-- 批量操作列 (限成本分攤，支援跨頁) -->
                    <div v-if="reservation.selectedIds.length > 0"
                         class="mb-2 p-2 bg-primary-subtle rounded">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="text-primary fw-semibold">已選取 {{ reservation.selectedIds.length }} 筆（成本分攤）</span>
                            <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#bulkApproveModal"
                                    @@click="reservation.bulkVm.discountType = 'none'; reservation.bulkVm.discountReason = ''; reservation.bulkVm.paymentDeadline = ''">
                                <span class="material-icons" style="font-size:16px;vertical-align:middle;">done_all</span>
                                批量核准
                            </button>
                            <button class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#bulkRejectModal"
                                    @@click="reservation.bulkRejectVm.reason = ''">
                                <span class="material-icons" style="font-size:16px;vertical-align:middle;">block</span>
                                批量拒絕
                            </button>
                            <button class="btn btn-sm btn-outline-secondary ms-auto" @@click="reservation.clearSelection()">
                                全部取消
                            </button>
                        </div>
                    </div>

                    <table class="table table-hover reservation-table">
                        <caption>租借審核列表</caption>
                        <thead>
                            <tr class="table-light">
                                <th style="width:36px;" title="批量審核限成本分攤，支援跨頁選取">
                                    <input type="checkbox" class="form-check-input"
                                           :checked="reservation.isAllSelected.value"
                                           @@click="reservation.toggleAll()">
                                </th>
                                <th style="width:120px;">預約單號</th>
                                <th>申請人</th>
                                <th>日期</th>
                                <th>會議室</th>
                                <th>金額</th>
                                <th>審核進度</th>
                                <th>動作</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr v-for="item in reservation.approvalList" :key="item.id"
                                :class="{ 'table-primary': reservation.selectedIds.includes(item.id) }">
                                <td>
                                    <input v-if="item.status === '待審核' && item.paymentMethod === 'cost-sharing'"
                                           type="checkbox" class="form-check-input"
                                           :checked="reservation.selectedIds.includes(item.id)"
                                           @@click="reservation.toggleSelect(item)">
                                </td>
                                <td>{{ item.bookingNo }}</td>
                                <td>{{ item.applicantName }}</td>
                                <td>{{ item.date }}</td>
                                <td>{{ item.roomName }}</td>
                                <td>NT${{ item.totalAmount.toLocaleString() }}</td>
                                <td>
                                    <!-- ✅ 根據狀態顯示不同內容 -->
                                    <span v-if="item.status === '待審核'" class="badge bg-info">
                                        第 {{ item.currentApprovalLevel + 1 }}/{{ item.totalApprovalLevels }} 關
                                    </span>
                                    <span v-else-if="item.status === '已核准'" class="badge bg-success">已核准</span>
                                    <span v-else-if="item.status === '已拒絕'" class="badge bg-danger">已拒絕</span>
                                    <span v-else class="badge bg-secondary">{{ item.status }}</span>
                                </td>
                                <td>
                                    <button v-if="item.status === '待審核'" class="btn btn-sm btn-outline-primary"
                                        @@click="reservation.openApprovalReview(item)" data-bs-toggle="offcanvas"
                                            data-bs-target="#approvalDrawer">
                                        審核
                                    </button>
                                    <button v-else class="btn btn-sm btn-outline-secondary"
                                        @@click="reservation.openApprovalReview(item)" data-bs-toggle="offcanvas"
                                            data-bs-target="#approvalDrawer">
                                        <span class="material-icons">visibility</span> 查看
                                    </button>
                                </td>
                            </tr>
                            <tr v-if="reservation.approvalList.length === 0">
                                <td colspan="8" class="text-center text-muted">
                                    {{ reservation.query.reservationStatus ? '沒有符合條件的資料' : '目前沒有待審核的租借申請' }}
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- ✅ 加入分頁元件 -->
                    <page ref="approvalPage" @@reload="reservation.getApprovalList"></page>
                </div>

                <!-- ✅ 付款審核列表（以 Order 為單位） -->
                <div v-show="reservation.activeTab.value === 'payment'">
                    <table class="table table-hover">
                        <caption>付款審核列表</caption>
                        <thead>
                            <tr class="table-light">
                                <th>申請人</th>
                                <th>付款方式</th>
                                <th>合計金額</th>
                                <th>筆數</th>
                                <th>狀態</th>
                                <th>上傳時間</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr v-for="item in reservation.paymentList" :key="item.orderId"
                                @@click="reservation.openPaymentReview(item)" class="row-click" style="cursor: pointer;"
                                data-bs-toggle="offcanvas" data-bs-target="#paymentDrawer">
                                <td>{{ item.applicantName }}</td>
                                <td>{{ getPaymentMethodText(item.paymentMethod) }}</td>
                                <td>NT${{ item.totalAmount.toLocaleString() }}</td>
                                <td>{{ item.conferenceCount }} 筆</td>
                                <td>
                                    <span class="badge"
                                          :class="item.orderStatus === '已收款' ? 'bg-success' : item.orderStatus === '已退回' ? 'bg-danger' : 'bg-warning text-dark'">
                                        {{ item.orderStatus }}
                                    </span>
                                </td>
                                <td>{{ item.uploadTime || '-' }}</td>
                            </tr>
                            <tr v-if="reservation.paymentList.length === 0">
                                <td colspan="6" class="text-center text-muted">
                                    目前沒有待審核的付款訂單
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- ✅ 加入分頁元件 -->
                    <page ref="paymentPage" @@reload="reservation.getPaymentList"></page>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- ===== 租借審核抽屜 ===== -->
<div class="offcanvas offcanvas-end offcanvas-large" tabindex="-1" id="approvalDrawer"
     aria-labelledby="approvalDrawerLabel">
    <div class="offcanvas-header">
        <h5 id="approvalDrawerLabel">租借審核 <small class="text-muted">{{ reservation.currentReview.bookingNo }}</small>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body">
        <!-- 基本資料 -->
        <div class="border rounded p-3 bg-body-tertiary mb-3">
            <div class="row g-2 small">
                <div class="col-md-6"><strong>申請人:</strong> {{ reservation.currentReview.applicantName }}</div>
                <div class="col-md-6"><strong>會議室:</strong> {{ reservation.currentReview.roomName }}</div>
                <div class="col-md-6"><strong>日期:</strong> {{ reservation.currentReview.date }}</div>
                <div class="col-md-6"><strong>時間:</strong> {{ reservation.formatTimeDisplay(reservation.currentReview) }}</div>
                <div class="col-md-6" v-if="reservation.currentReview.organizerUnit">
                    <strong>主辦單位:</strong> {{ reservation.currentReview.organizerUnit }}
                </div>
                <div class="col-md-6" v-if="reservation.currentReview.expectedAttendees">
                    <strong>預計人數:</strong> {{ reservation.currentReview.expectedAttendees }} 人
                </div>
                <div class="col-md-6" v-if="reservation.currentReview.contactPhone">
                    <strong>聯絡電話:</strong> {{ reservation.currentReview.contactPhone }}
                </div>
                <div class="col-md-6" v-if="reservation.currentReview.contactEmail">
                    <strong>電子郵件:</strong> {{ reservation.currentReview.contactEmail }}
                </div>
                <div class="col-md-6">
                    <strong>租借金額:</strong> NT${{ reservation.currentReview.totalAmount?.toLocaleString() }}
                </div>
                <div class="col-md-6" v-if="reservation.currentReview.parkingTicketCount > 0">
                    <strong>停車券:</strong> {{ reservation.currentReview.parkingTicketCount }} 張
                </div>
            </div>
        </div>

        <!-- 繳費資訊 -->
        <div class="border rounded p-3 bg-body-tertiary mb-3">
            <h6 class="text-muted small mb-2">繳費資訊</h6>
            <div class="row g-2 small">
                <div class="col-md-6">
                    <strong>繳費方式:</strong> {{ getPaymentMethodText(reservation.currentReview.paymentMethod) || '-' }}
                </div>
                <div class="col-md-6" v-if="reservation.currentReview.paymentMethod === 'cost-sharing' && reservation.currentReview.departmentCode">
                    <strong>部門代碼:</strong> {{ reservation.currentReview.departmentCode }}
                </div>
                <div class="col-md-6" v-if="reservation.currentReview.paymentDeadline">
                    <strong>繳費期限:</strong> {{ reservation.currentReview.paymentDeadline }}
                </div>
            </div>
        </div>

        <!-- ===== 優惠證明（通用） ===== -->
        <template v-if="reservation.currentReview.discountProofPath">
            <div class="border rounded p-3 bg-body-tertiary mb-3">
                <h6 class="text-muted small mb-2">
                    <span class="material-icons" style="font-size: 16px; vertical-align: middle;">verified</span>
                    優惠證明
                </h6>
                <div class="text-center mb-2">
                    <img :src="reservation.currentReview.discountProofPath"
                         :alt="reservation.currentReview.discountProofName"
                         class="img-fluid rounded border" style="max-height: 300px; cursor: pointer;"
                         @@click="viewFullImage(reservation.currentReview.discountProofPath)" />
                </div>
                <p class="text-muted small text-center mb-0">{{ reservation.currentReview.discountProofName }}</p>
            </div>
        </template>

        <!-- ✅ 審核歷程（水平步驟進度條） -->
        <template v-if="reservation.currentReview.approvalHistory?.length > 0">
            <div class="mb-3">
                <h6 class="d-flex align-items-center text-primary border-bottom pb-2 mb-0 approval-header"
                    role="button" @@click="reservation.toggleApprovalHistory()">
                    <span class="material-icons me-1" style="font-size: 18px;">fact_check</span>
                    審核歷程
                    <span class="ms-2 badge" :class="reservation.getProgressBadgeClass(reservation.currentReview.approvalHistory)">
                        {{ reservation.getApprovalProgress(reservation.currentReview.approvalHistory) }}
                    </span>
                    <span class="material-icons ms-auto expand-icon" :class="{ 'rotated': reservation.approvalHistoryExpanded.value }">
                        expand_more
                    </span>
                </h6>
            </div>
            <!-- 展開的水平步驟 -->
            <div class="mb-3" v-show="reservation.approvalHistoryExpanded.value">
                <div class="steps-scroll">
                    <div class="steps">
                        <div v-for="(history, index) in reservation.currentReview.approvalHistory" :key="index"
                             class="step" :class="reservation.getStepClass(history)">
                            <!-- 圓形節點 -->
                            <div class="step-circle">
                                <template v-if="history.Status === 'Approved'">✓</template>
                                <template v-else-if="history.Status === 'Rejected'">✕</template>
                                <template v-else>{{ history.Level }}</template>
                            </div>
                            <!-- 文字區 -->
                            <div class="step-label">
                                <div class="step-name">第 {{ history.Level }} 關</div>
                                <div class="step-status">{{ history.StatusText }}</div>
                                <div v-if="reservation.currentReview.status === '審核拒絕' && history.Status === 'Approved'"
     class="text-danger" style="font-size:11px;">
    （審核拒絕）
</div>
                                <span v-if="history.Reason?.includes('決行') && !history.Reason?.includes('跳過')"
                                      class="step-tag tag-decision">決行</span>
                                <span v-else-if="history.Reason?.includes('跳過')"
                                      class="step-tag tag-skip">跳過</span>
                                <template v-if="history.ApproverName">
                                    <div class="step-reviewer">{{ history.ApproverName }}</div>
                                    <div v-if="history.ApprovedByName && history.ApprovedByName !== history.ApproverName"
                                         class="step-meta">（{{ history.ApprovedByName }} 代理）</div>
                                </template>
                                <div v-if="history.ApprovedAt" class="step-meta">{{ history.ApprovedAt }}</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="scroll-hint text-center text-muted small" v-if="reservation.currentReview.approvalHistory?.length > 4">
                    ← 左右滑動查看更多 →
                </div>
            </div>
        </template>

        <hr>

        <!-- ✅ 只有「待審核」才顯示表單,其他狀態只顯示資訊 -->
        <div v-if="reservation.currentReview.status === '待審核'">
            <form class="row g-3">
                <!-- 審核決策 -->
                <div class="col-12">
                    <label class="form-label">審核結果</label>
                    <div class="d-flex gap-4">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="approval-result" id="approval-approve"
                                   value="approve" v-model="reservation.vm.result">
                            <label class="form-check-label" for="approval-approve">核准</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="approval-result" id="approval-reject"
                                   value="reject" v-model="reservation.vm.result">
                            <label class="form-check-label" for="approval-reject">拒絕</label>
                        </div>
                        <!-- 決行：只有在還有後續關卡時才顯示 -->
                        <div class="form-check" v-if="reservation.currentReview.totalApprovalLevels > reservation.currentReview.currentApprovalLevel + 1">
                            <input class="form-check-input" type="radio" name="approval-result" id="approval-fasttrack"
                                   value="fasttrack" v-model="reservation.vm.result">
                            <label class="form-check-label text-success fw-bold" for="approval-fasttrack">
                                <i class="mdi mdi-check-all"></i> 決行
                            </label>
                            <small class="text-muted d-block">（直接通過，跳過後續 {{ reservation.currentReview.totalApprovalLevels - reservation.currentReview.currentApprovalLevel - 1 }} 關）</small>
                        </div>
                    </div>
                </div>

                <!-- 拒絕原因 -->
                <div v-if="reservation.vm.result === 'reject'" class="col-12">
                    <label class="form-label">拒絕原因 <span class="text-danger">*</span></label>
                    <textarea class="form-control" v-model="reservation.vm.rejectReason" rows="2" placeholder="請填寫拒絕原因"
                              required></textarea>
                </div>

                <!-- 折扣設定（第一關才顯示，核准或決行時） -->
                <div v-if="(reservation.vm.result === 'approve' || reservation.vm.result === 'fasttrack') && reservation.currentReview.currentApprovalLevel === 0" class="col-12">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">折扣方式</label>
                            <select class="form-select" v-model="reservation.vm.discountType">
                                <option value="none">無折扣</option>
                                <option value="percent">百分比折扣 (%)</option>
                                <option value="amount">金額折扣 (NT$)</option>
                                <option value="free">免單</option>
                            </select>
                        </div>

                        <div v-if="reservation.vm.discountType === 'percent'" class="col-md-6">
                            <label class="form-label">折扣％</label>
                            <div class="input-group">
                                <input type="number" class="form-control"
                                       v-model.number="reservation.vm.discountPercent" min="0" max="100" step="1">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>

                        <div v-if="reservation.vm.discountType === 'amount'" class="col-md-6">
                            <label class="form-label">折扣金額 (NT$)</label>
                            <input type="number" class="form-control" v-model.number="reservation.vm.discountAmount"
                                   min="0" step="1">
                        </div>

                        <div v-if="reservation.vm.discountType !== 'none'" class="col-12">
                            <label class="form-label">
                                原因
                                <span v-if="reservation.vm.discountType === 'free'" class="text-danger">*</span>
                            </label>
                            <textarea class="form-control" v-model="reservation.vm.discountReason" rows="2"
                                      :required="reservation.vm.discountType === 'free'"></textarea>
                        </div>

                        <!-- 繳費期限 -->
                        <div class="col-md-6">
                            <label class="form-label">繳費期限</label>
                            <input type="date" class="form-control" v-model="reservation.vm.paymentDeadline"
                                   :min="reservation.today">
                            <div class="form-text text-muted">不填則使用系統預設期限</div>
                        </div>

                        <!-- 價格明細 -->
                        <div class="col-12">
                            <div class="border rounded p-3 bg-body-secondary">
                                <h6 class="mb-3">價格明細</h6>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="text-muted">原價:</span><strong>NT${{
                                        reservation.pricing.original.toLocaleString() }}</strong></li>
                                        <li><span class="text-muted">折扣:</span><strong>-NT${{
                                            reservation.pricing.discount.toLocaleString() }}</strong></li>
                                        </ul>
                                        <hr class="my-2">
                                        <div class="d-flex justify-content-between">
                                            <span class="fw-bold">合計:</span>
                                            <strong class="text-primary">NT${{ reservation.pricing.final.toLocaleString()
                                                }}</strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- 按鈕 -->
                            <div class="col-12 d-flex gap-2" style="justify-content: flex-end;">
                                <button type="button" @@click="reservation.submitApprovalReview"
                                        class="btn btn-primary">確認送出</button>
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="offcanvas">取消</button>
                            </div>
                        </form>
                    </div>

                    <!-- ✅ 已處理的狀態顯示 -->
                    <div v-else>
                        <div class="alert" :class="{
                            'alert-success': reservation.currentReview.status === '待繳費',
                            'alert-danger': reservation.currentReview.status === '審核拒絕'
                            }">
                            <h6 class="alert-heading">
                                <span class="material-icons me-2">info</span>
                                此預約已審核
                            </h6>
                            <p class="mb-0">
                                <strong>狀態:</strong> {{ reservation.currentReview.status }}
                            </p>
                            <p v-if="reservation.currentReview.rejectReason" class="mb-0 mt-2">
                                <strong>原因:</strong> {{ reservation.currentReview.rejectReason }}
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== 付款審核抽屜 ===== -->
            <div class="offcanvas offcanvas-end offcanvas-large" tabindex="-1" id="paymentDrawer"
                 aria-labelledby="paymentDrawerLabel">
                <div class="offcanvas-header">
                    <h5 id="paymentDrawerLabel">付款審核</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
                </div>
                <div class="offcanvas-body">
                    <!-- 訂單摘要 -->
                    <div class="border rounded p-3 bg-body-tertiary mb-3">
                        <div class="row g-2 small">
                            <div class="col-md-6"><strong>申請人:</strong> {{ reservation.currentPayment.applicantName }}</div>
                            <div class="col-md-6"><strong>合計金額:</strong> NT${{ reservation.currentPayment.totalAmount?.toLocaleString() }}</div>
                            <div class="col-md-6"><strong>付款方式:</strong> {{ getPaymentMethodText(reservation.currentPayment.paymentMethod) }}</div>
                            <div class="col-md-6"><strong>上傳時間:</strong> {{ reservation.currentPayment.uploadTime || '-' }}</div>
                        </div>
                    </div>

                    <!-- 訂單明細 -->
                    <div class="mb-3" v-if="reservation.currentPayment.items && reservation.currentPayment.items.length > 0">
                        <h6 class="text-secondary mb-2">預約明細（{{ reservation.currentPayment.items.length }} 筆）</h6>
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>預約單號</th>
                                    <th>會議名稱</th>
                                    <th>日期</th>
                                    <th class="text-end">金額</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="i in reservation.currentPayment.items" :key="i.ConferenceId">
                                    <td>{{ i.BookingNo }}</td>
                                    <td class="text-ellipsis">{{ i.ConferenceName }}</td>
                                    <td>{{ i.Date }}</td>
                                    <td class="text-end">NT${{ i.TotalAmount?.toLocaleString() }}</td>
                                </tr>
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">合計</td>
                                    <td class="text-end fw-bold">NT${{ reservation.currentPayment.totalAmount?.toLocaleString() }}</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <hr>
                        <!-- 付款資訊 -->
                        <div class="mb-4">
                            <h6 class="mb-2">
                                <span class="material-icons">payment</span>
                                付款資訊
                            </h6>

                            <div class="alert alert-info">
                                <p class="mb-2">
                                    <strong>付款方式:</strong>
                                    {{ getPaymentMethodText(reservation.currentPayment.paymentMethod) }}
                                </p>
                                <p class="mb-2" v-if="reservation.currentPayment.paymentMethod === '臨櫃'">
                                    <strong>憑證上傳時間:</strong>
                                    {{ reservation.currentPayment.uploadTime || '-' }}
                                </p>

                                <p class="mb-2" v-if="reservation.currentPayment.paymentMethod === '匯款'">
                                    <strong>提交時間:</strong>
                                    {{ reservation.currentPayment.uploadTime || '-' }}
                                </p>

                                <!-- ===== 匯款資訊 ===== -->
                                <template v-if="reservation.currentPayment.paymentMethod === '匯款'">
                                    <hr class="my-2">
                                    <h6 class="text-muted small mb-2">匯款資訊</h6>
                                    <p class="mb-1">
                                        <strong>轉帳末五碼:</strong>
                                        {{ reservation.currentPayment.lastFiveDigits || '-' }}
                                    </p>
                                    <p class="mb-1">
                                        <strong>轉帳金額:</strong>
                                        NT${{ reservation.currentPayment.transferAmount?.toLocaleString() || '-' }}
                                    </p>
                                    <p class="mb-1">
                                        <strong>轉帳時間:</strong>
                                        {{ reservation.currentPayment.transferAt || '-' }}
                                    </p>
                                    <p class="mb-0" v-if="reservation.currentPayment.note">
                                        <strong>備註:</strong>
                                        <span class="text-muted">{{ reservation.currentPayment.note }}</span>
                                    </p>
                                    <!-- 匯款截圖（選填） -->
                                    <template v-if="reservation.currentPayment.filePath && reservation.currentPayment.filePath !== '-'">
                                        <hr class="my-2">
                                        <h6 class="text-muted small mb-2">匯款截圖</h6>
                                        <div class="text-center mb-2">
                                            <img :src="reservation.currentPayment.filePath"
                                                 :alt="reservation.currentPayment.fileName"
                                                 class="img-fluid rounded border" style="max-height: 400px; cursor: pointer;"
                                                 @@click="viewFullImage(reservation.currentPayment.filePath)" />
                                        </div>
                                        <p class="text-muted small text-center mb-0">
                                            {{ reservation.currentPayment.fileName }}
                                        </p>
                                    </template>
                                </template>

                                <!-- ===== 臨櫃 ===== -->
                                <template v-else-if="reservation.currentPayment.paymentMethod === '臨櫃'">
                                    <hr class="my-2">
                                    <h6 class="text-muted small mb-2">付款憑證</h6>
                                    <div class="text-center mb-2">
                                        <img :src="reservation.currentPayment.filePath" :alt="reservation.currentPayment.fileName"
                                             class="img-fluid rounded border" style="max-height: 400px; cursor: pointer;"
                                        @@click="viewFullImage(reservation.currentPayment.filePath)" />
                                    </div>
                                    <p class="text-muted small text-center mb-2">
                                        {{ reservation.currentPayment.fileName }}
                                    </p>
                                    <p class="mb-0" v-if="reservation.currentPayment.note">
                                        <strong>備註:</strong>
                                        <span class="text-muted">{{ reservation.currentPayment.note }}</span>
                                    </p>
                                </template>

                                <!-- ===== 優惠證明（通用） ===== -->
                                <template v-if="reservation.currentPayment.discountProofPath">
                                    <hr class="my-2">
                                    <h6 class="text-muted small mb-2">
                                        <span class="material-icons" style="font-size: 16px;">verified</span>
                                        優惠證明
                                    </h6>
                                    <div class="text-center mb-2">
                                        <img :src="reservation.currentPayment.discountProofPath"
                                             :alt="reservation.currentPayment.discountProofName"
                                             class="img-fluid rounded border" style="max-height: 300px; cursor: pointer;"
                                             @@click="viewFullImage(reservation.currentPayment.discountProofPath)" />
                                    </div>
                                    <p class="text-muted small text-center mb-0">
                                        {{ reservation.currentPayment.discountProofName }}
                                    </p>
                                </template>
                            </div>
                        </div>

                        <template v-if="reservation.currentPayment.orderStatus === '待查帳'">
                        <hr>

                        <form class="row g-3">
                            <!-- 審核決策 -->
                            <div class="col-12">
                                <label class="form-label">審核結果</label>
                                <div class="d-flex gap-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="payment-result" id="payment-approve"
                                               value="approve" v-model="reservation.paymentVm.result">
                                        <label class="form-check-label" for="payment-approve">批准收款</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="payment-result" id="payment-reject"
                                               value="reject" v-model="reservation.paymentVm.result">
                                        <label class="form-check-label" for="payment-reject">退回重審</label>
                                    </div>
                                </div>
                            </div>

                            <!-- 退回原因 -->
                            <div v-if="reservation.paymentVm.result === 'reject'" class="col-12">
                                <label class="form-label">退回原因 <span class="text-danger">*</span></label>
                                <select class="form-select mb-2" v-model="reservation.paymentVm.rejectTemplate"
                                        @@change="reservation.onRejectTemplateChange()">
                                    <option value="">請選擇退回原因…</option>
                                    <option value="未夾帶證明文件">未夾帶證明文件</option>
                                    <option value="場租折扣不符合管理規定">場租折扣不符合管理規定</option>
                                    <option value="租借日期與時段與來信或來電不相符">租借日期與時段與來信或來電不相符</option>
                                    <option value="__custom__">自行輸入…</option>
                                </select>
                                <textarea v-if="reservation.paymentVm.rejectTemplate === '__custom__'"
                                          class="form-control" v-model="reservation.paymentVm.rejectReason" rows="3"
                                          placeholder="請填寫退回原因" required></textarea>
                            </div>

                            <!-- 按鈕 -->
                            <div class="col-12 d-flex gap-2" style="justify-content: flex-end;">
                                <button type="button" @@click="reservation.submitPaymentReview" class="btn btn-primary">確認送出</button>
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="offcanvas">取消</button>
                            </div>
                        </form>
                        </template>
                    </div>
                </div>

<!-- ===== 批量核准 Modal ===== -->
<div class="modal fade" id="bulkApproveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">批量核准</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3">共選取 <strong>{{ reservation.selectedIds.length }}</strong> 筆待審核預約，以下設定將統一套用。</p>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">折扣方式</label>
                        <select class="form-select" v-model="reservation.bulkVm.discountType">
                            <option value="none">無折扣</option>
                            <option value="percent">百分比折扣 (%)</option>
                            <option value="amount">每筆金額折扣 (NT$)</option>
                            <option value="free">全部免單</option>
                        </select>
                    </div>
                    <div v-if="reservation.bulkVm.discountType === 'percent'" class="col-12">
                        <label class="form-label">折扣％</label>
                        <div class="input-group">
                            <input type="number" class="form-control" v-model.number="reservation.bulkVm.discountPercent" min="0" max="100">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                    <div v-if="reservation.bulkVm.discountType === 'amount'" class="col-12">
                        <label class="form-label">每筆折扣金額 (NT$)</label>
                        <input type="number" class="form-control" v-model.number="reservation.bulkVm.discountAmount" min="0">
                    </div>
                    <div v-if="reservation.bulkVm.discountType !== 'none'" class="col-12">
                        <label class="form-label">
                            折扣原因
                            <span v-if="reservation.bulkVm.discountType === 'free'" class="text-danger">*</span>
                        </label>
                        <textarea class="form-control" v-model="reservation.bulkVm.discountReason" rows="2"></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label">繳費期限</label>
                        <input type="date" class="form-control" v-model="reservation.bulkVm.paymentDeadline" :min="reservation.today">
                        <div class="form-text">不填則使用系統預設期限</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" @@click="reservation.submitBulkApprove()">確認核准</button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
            </div>
        </div>
    </div>
</div>

<!-- ===== 批量拒絕 Modal ===== -->
<div class="modal fade" id="bulkRejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">批量拒絕</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3">共選取 <strong>{{ reservation.selectedIds.length }}</strong> 筆待審核預約，將統一拒絕。</p>
                <div>
                    <label class="form-label">拒絕原因 <span class="text-danger">*</span></label>
                    <textarea class="form-control" v-model="reservation.bulkRejectVm.reason" rows="3"
                              placeholder="請填寫拒絕原因"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" @@click="reservation.submitBulkReject()">確認拒絕</button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
            </div>
        </div>
    </div>
</div>

<!-- 圖片放大 Modal -->
<div class="modal fade" id="imagePreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-transparent border-0 position-relative">
            <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-2"
                    style="z-index:10;" data-bs-dismiss="modal"></button>
            <div class="modal-body text-center p-2">
                <img :src="fullImageUrl" class="img-fluid rounded" style="max-height:85vh;object-fit:contain;">
            </div>
        </div>
    </div>
</div>