@using TASA.Services.AuthModule
@{
    var user = UserClaimsService.ToAuthUser(Context.User.Claims);
    var isGlobalAdmin = user?.IsGlobalAdmin == true;
}
<div v-cloak>
<div class="page-content">
    <div class="container-fluid vstack gap-3">
        <div class="card">
            <div class="card-header mx-4 mt-3">
                <div class="row d-flex align-items-center">
                    <div class="col-xl-auto col-sm-12 text-branding d-flex align-items-center">
                        <span class="material-icons">people</span>使用者總覽
                    </div>

                    <div class="col-12 col-lg-3">
                        <div class="search-box">
                            <div class="position-relative">
                                <input type="text" class="form-control" v-model="authuser.query.keyword"
                                       placeholder="搜尋關鍵字...">
                                <span class="material-icons search-icon">search</span>
                            </div>
                        </div>
                    </div>

                    @if (isGlobalAdmin)
                    {
                        <div class="col-12 col-lg-3">
                            <select class="form-select" v-model="departmentFilter">
                                <option :value="null">全部分院</option>
                                <template v-for="{Id,Name,Children} in department.tree">
                                    <optgroup v-if="Children && Children.length > 0" :label="Name">
                                        <option :value="Id">{{ Name }}</option>
                                        <option v-for="child in Children" :key="child.Id" :value="child.Id">{{ child.Name }}</option>
                                    </optgroup>
                                    <option v-else :key="Id" :value="Id">{{ Name }}</option>
                                </template>
                            </select>
                        </div>
                    }

                    <div class="col-12 col-lg-3">
                        <div class="position-relative unit-filter-container">
                            <input type="text" class="form-control" v-model="unitFilterInput"
                                   @@focus="unitFilterDropdown = true"
                                   @@input="unitFilterDropdown = true"
                                   placeholder="篩選部門..." autocomplete="off">
                            <div v-if="unitFilterDropdown && unitFilterFiltered.length > 0"
                                 class="position-absolute w-100 bg-white border rounded shadow-sm"
                                 style="max-height: 200px; overflow-y: auto; z-index: 1050;">
                                <div class="px-3 py-2 text-muted" style="cursor:pointer; font-size:0.85rem;"
                                     @@click="unitFilterInput = ''; unitFilterDropdown = false">
                                    全部部門
                                </div>
                                <div v-for="item in unitFilterFiltered" :key="item.Code"
                                     class="px-3 py-2" style="cursor: pointer;"
                                     @@click="unitFilterInput = item.Name; unitFilterDropdown = false"
                                     @@mouseover="$event.target.style.backgroundColor='#f8f9fa'"
                                     @@mouseout="$event.target.style.backgroundColor=''">
                                    {{ item.Name }}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-auto d-flex align-items-center ms-auto">
                        @* <button @@click="authuser.getVM()" class="btn btn-primary d-flex align-items-center"
                            data-bs-toggle="modal" data-bs-target="#authUserModal">
                            <span class="material-icons me-2">add</span> 新增使用者
                        </button> *@
                    </div>
                </div>
            </div>
            <div class="card-body">
                <ul class="nav nav-tabs">
                    <li v-for="item in tabs.list" class="nav-item">
                        <div @@click="tabs.click(item.value)"
                            v-bind:class="['nav-link',{'active':tabs.select.value==item.value}]" role="button">
                            {{item.text}}</div>
                    </li>
                </ul>
                <table class="table table-hover table-responsive authuser-table">
                    <caption>使用者列表</caption>
                    <thead>
                        <tr class="table-light">
                            <th>分院</th>
                            <th>部門</th>
                            <th>姓名</th>
                            <th>Email</th>
                            <th>狀態</th>
                            <th>建立日期</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="item in tabData" @@dblclick="authuser.getVM(item.Id)" :key="item.Id">
                            <td>{{item.DepartmentName}}</td>
                            <td>{{item.UnitName}}</td>
                            <td>{{item.Name}}</td>
                            <td>{{item.Email}}</td>
                            <td>
                                <span v-if="item.IsEnabled" class="badge bg-success">啟用</span>
                                <span v-else-if="!item.IsApproved" class="badge bg-warning text-dark">待審核</span>
                                <span v-else class="badge bg-danger">停用</span>
                            </td>
                            <td>{{item.CreateAt.format()}}</td>
                            <td>
                                <button @@click="authuser.getVM(item.Id)" class="btn btn-sm btn-outline-primary">編輯</button>
                                <button v-if="!item.IsEnabled && !item.IsApproved"
                                        @@click="authuser.showRejectModal(item)"
                                        class="btn btn-sm btn-outline-danger ms-1">拒絕</button>
                            </td>
                        </tr>
                    </tbody>
                    <tfoot v-if="tabData.length==0">
                        <tr>
                            <td colspan="7" class="text-center text-muted">查無資料</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
<!-- ===== 新增/編輯 Modal ===== -->
<div class="modal fade" id="authUserModal" tabindex="-1" aria-labelledby="authUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <!-- Modal Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="authUserModalLabel">
                    {{ authuser.vm.Id ? '編輯使用者' : '新增使用者' }}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Modal Body -->
            <div class="modal-body px-4 mt-3">
                <form>
                    <!-- 姓名 -->
                    <div class="row mb-4">
                        <label class="col-sm-3 col-form-label">姓名 <span class="text-danger">*</span></label>
                        <div class="col-sm-9">
                            <input v-model="authuser.vm.Name" type="text" class="form-control" placeholder="姓名">
                        </div>
                    </div>

                    <!-- 帳號 (僅新增時顯示) -->
                    <div v-if="!authuser.vm.Id" class="row mb-4">
                        <label class="col-sm-3 col-form-label">帳號 <span class="text-danger">*</span></label>
                        <div class="col-sm-9">
                            <input v-model="authuser.vm.Account" type="text" class="form-control" placeholder="帳號">
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="row mb-4">
                        <label class="col-sm-3 col-form-label">Email</label>
                        <div class="col-sm-9">
                            <input v-model="authuser.vm.Email" type="email" class="form-control" placeholder="Email">
                        </div>
                    </div>

                    <!-- 分院 -->
                    <div class="row mb-4">
                        <label class="col-sm-3 col-form-label">分院</label>
                        <div class="col-sm-9">
                            <select v-model="authuser.vm.DepartmentId" class="form-select">
                                <option :value="null">請選擇分院</option>
                                <template v-for="{Id,Name,Children} in department.tree">
                                    <optgroup v-if="Children && Children.length > 0" :label="Name">
                                        <option :value="Id">{{ Name }}</option>
                                        <option v-for="child in Children" :key="child.Id" :value="child.Id">
                                            {{ child.Name }}
                                        </option>
                                    </optgroup>
                                    <option v-else :key="Id" :value="Id">{{ Name }}</option>
                                </template>
                            </select>
                        </div>
                    </div>

                    <!-- 部門 -->
                    <div class="row mb-4">
                        <label class="col-sm-3 col-form-label">部門</label>
                        <div class="col-sm-9">
                            <div class="position-relative unit-dropdown-container">
                                <input type="text" class="form-control"
                                       v-model="costCenter.search.value"
                                       @@input="costCenter.filter(); authuser.vm.UnitName = costCenter.search.value"
                                       @@focus="costCenter.onFocus()"
                                       placeholder="輸入部門名稱搜尋..." autocomplete="off">

                                <!-- 下拉選項列表 -->
                                <div v-if="costCenter.showDropdown.value && costCenter.filtered.value.length > 0"
                                     class="position-absolute w-100 bg-white border rounded shadow-sm"
                                     style="max-height: 200px; overflow-y: auto; z-index: 1050;">
                                    <div v-for="item in costCenter.filtered.value" :key="item.Code"
                                         class="px-3 py-2"
                                         style="cursor: pointer;"
                                         @@click="costCenter.select(item)"
                                         @@mouseover="$event.target.style.backgroundColor='#f8f9fa'"
                                         @@mouseout="$event.target.style.backgroundColor=''">
                                        {{ item.Name }}
                                    </div>
                                </div>
                                <div v-if="costCenter.showDropdown.value && costCenter.filtered.value.length === 0"
                                     class="position-absolute w-100 bg-white border rounded shadow-sm p-2 text-muted"
                                     style="z-index: 1050;">
                                    查無結果
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 角色 -->
                    <div class="row mb-4">
                        <label class="col-sm-3 col-form-label">角色</label>
                        <div class="col-sm-9">
                            <div class="dropdown">
                                <button class="form-select text-start" type="button"
                                        data-bs-toggle="dropdown" data-bs-auto-close="outside">
                                    {{ authuser.vm.Role.length > 0
                                        ? role.list.filter(r => authuser.vm.Role.includes(r.Id)).map(r => r.Name).join('、')
                                        : '請選擇角色' }}
                                </button>
                                <ul class="dropdown-menu w-100 px-2">
                                    <li v-for="item in role.list" :key="item.Id" class="dropdown-item p-0 ms-3">
                                        <label class="form-check mb-0 px-3 py-2 w-100" style="cursor:pointer;">
                                            <input v-model="authuser.vm.Role" class="form-check-input"
                                                   type="checkbox" :value="item.Id">
                                            {{item.Name}}
                                        </label>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- 啟用 -->
                    <div class="row mb-4">
                        <label class="col-sm-3 col-form-label">啟用</label>
                        <div class="col-sm-9 d-flex align-items-center gap-3">
                            <label class="form-check">
                                <input v-model="authuser.vm.IsEnabled" class="form-check-input" type="radio"
                                    :value="true">
                                是
                            </label>
                            <label class="form-check">
                                <input v-model="authuser.vm.IsEnabled" class="form-check-input" type="radio"
                                    :value="false">
                                否
                            </label>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Modal Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" @@click="authuser.save()">
                    {{ authuser.vm.Id ? '確認修改' : '確認新增' }}
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ===== 拒絕帳號 Modal ===== -->
<div class="modal fade" id="rejectUserModal" tabindex="-1" aria-labelledby="rejectUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="rejectUserModalLabel">拒絕帳號申請</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 mt-3">
                <p>確定要拒絕 <strong>{{ authuser.rejectVM.userName }}</strong> 的帳號申請嗎？</p>
                <p class="text-muted small">拒絕後將刪除該帳號，並發送通知信給申請者。</p>
                <div class="mb-3">
                    <label class="form-label">拒絕原因</label>
                    <textarea v-model="authuser.rejectVM.reason" class="form-control" rows="3"
                              placeholder="選填，將會寄送給申請者..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-danger" @@click="authuser.confirmReject()">確認拒絕</button>
            </div>
        </div>
    </div>
</div>
</div>